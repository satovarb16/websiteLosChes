<style>
/* ─── NAV ─────────────────────────────────────────────────────────────────── */
.site-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: var(--z-sticky);
  transition: background-color var(--duration-base) var(--ease-out),
              backdrop-filter var(--duration-base) var(--ease-out),
              border-color var(--duration-base) var(--ease-out);
  border-bottom: 1px solid transparent;
}

.site-nav.is-scrolled {
  background-color: oklch(0.13 0.01 50 / 0.9);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  border-bottom-color: var(--color-border);
}

.nav-inner {
  display: flex;
  align-items: center;
  gap: var(--space-8);
  padding-block: var(--space-4);
}

.nav-logo img { height: 48px; width: 48px; }

.nav-menu { flex: 1; }

.nav-menu ul {
  display: flex;
  align-items: center;
  gap: var(--space-6);
  justify-content: center;
}

.nav-link {
  font-size: 0.875rem;
  font-weight: 400;
  color: var(--color-ink-muted);
  text-decoration: none;
  transition: color var(--duration-fast) var(--ease-out);
  position: relative;
}

.nav-link::after {
  content: '';
  position: absolute;
  bottom: -3px;
  left: 0;
  right: 0;
  height: 1px;
  background-color: var(--color-primary);
  transform: scaleX(0);
  transition: transform 200ms var(--ease-out);
}

@media (hover: hover) and (pointer: fine) {
  .nav-link:hover { color: var(--color-ink); }
  .nav-link:hover::after { transform: scaleX(1); }
}
.nav-link[aria-current="true"]::after { transform: scaleX(1); }
.nav-link[aria-current="true"] { color: var(--color-ink); }

.nav-cta { white-space: nowrap; }

.nav-toggle {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: var(--space-2);
  margin-left: auto;
}

.nav-toggle span {
  display: block;
  width: 24px;
  height: 1.5px;
  background-color: var(--color-ink);
  transition: transform var(--duration-base) var(--ease-out),
              opacity var(--duration-fast) var(--ease-out);
}

.nav-toggle[aria-expanded="true"] span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
.nav-toggle[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
.nav-toggle[aria-expanded="true"] span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

@media (max-width: 768px) {
  .nav-toggle { display: flex; }
  .nav-cta { display: none; }

  .nav-menu {
    position: fixed;
    inset: 0;
    top: 73px;
    background-color: var(--color-bg);
    padding: var(--space-8) var(--space-6);
    transform: translateX(100%);
    transition: transform var(--duration-slow) var(--ease-out);
    z-index: var(--z-overlay);
  }

  .nav-menu.is-open { transform: translateX(0); }

  .nav-menu ul {
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-6);
  }

  .nav-link { font-size: 1.25rem; }
}


/* ─── HERO ────────────────────────────────────────────────────────────────── */
.hero {
  min-height: 100svh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding-top: 80px;
  position: relative;
  overflow: hidden;
}

.hero-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-16);
  align-items: center;
  padding-block: clamp(4rem, 8vw, 8rem);
  position: relative;
  z-index: 1;
}

.hero-text {
  transition: opacity 600ms var(--ease-out), transform 600ms var(--ease-out);
}

@starting-style {
  .hero-text  { opacity: 0; transform: translateY(20px); }
  .hero-image { opacity: 0; }
}

.hero-eyebrow {
  font-family: var(--font-body);
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-primary);
  margin-bottom: var(--space-4);
}

.hero-heading {
  font-size: clamp(3.5rem, 7vw, 6.5rem);
  font-weight: 700;
  line-height: 1.02;
  letter-spacing: -0.03em;
  margin-bottom: var(--space-6);
  max-width: 12ch;
}

.hero-heading em {
  display: inline-block;
  font-style: italic;
  color: var(--color-primary);
  transition: transform 1000ms 200ms var(--ease-out);
}

@starting-style {
  .hero-heading em { transform: translateX(-20px); }
}

.hero-body {
  font-size: clamp(1rem, 1.5vw, 1.125rem);
  color: var(--color-ink-muted);
  line-height: 1.7;
  margin-bottom: var(--space-8);
}

.hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-4);
}

.hero-image {
  position: relative;
  transition: opacity 600ms 120ms var(--ease-out), transform 600ms 120ms var(--ease-out);
}


.hero-img {
  width: 100%;
  aspect-ratio: 3/4;
  object-fit: cover;
  border-radius: var(--radius-lg);
  display: block;
}


@media (max-width: 768px) {
  .hero-inner {
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  .hero-image { order: -1; }

}

/* ─── STORY ───────────────────────────────────────────────────────────────── */
.story {
  padding-block: clamp(4rem, 8vw, 8rem);
}

.story--image-right { background-color: oklch(0.17 0.012 50 / 0.55); }

.story-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: clamp(3rem, 6vw, 6rem);
  align-items: center;
}

.story--image-right .story-inner {
  direction: rtl;
}

.story--image-right .story-inner > * {
  direction: ltr;
}

.story-text { }

.story-text h2 {
  font-size: clamp(2rem, 3.5vw, 3.25rem);
  margin-bottom: var(--space-6);
}

.accent       { color: var(--color-primary); font-style: italic; }
.accent-ember { color: var(--color-secondary); font-style: italic; }

.story-text p {
  color: var(--color-ink-muted);
  line-height: 1.75;
  margin-bottom: var(--space-4);
}

.pull-quote {
  position: relative;
  font-family: var(--font-display);
  font-style: italic;
  font-size: clamp(1.25rem, 2.5vw, 1.75rem);
  color: var(--color-primary);
  margin-block: var(--space-8);
  padding-left: var(--space-8);
  quotes: none;
  max-width: 36ch;
}

.pull-quote::before {
  content: '\201C';
  position: absolute;
  left: 0;
  top: -0.5rem;
  font-family: var(--font-display);
  font-size: 5rem;
  line-height: 1;
  color: var(--color-primary);
  opacity: 0.22;
  font-style: normal;
}

.story-img {
  aspect-ratio: 4/5;
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: var(--radius-lg);
  display: block;
}

/* Story images — fade + ligero scale-up para sensación cinematográfica */
.story-image[data-reveal] {
  opacity: 0;
  transform: scale(0.97);
  transition:
    opacity 700ms var(--ease-out),
    transform 700ms var(--ease-out);
}

.story-image[data-reveal].is-visible {
  opacity: 1;
  transform: scale(1);
}

.story-image[data-reveal-delay="1"] {
  transition-delay: 80ms;
}

@media (max-width: 768px) {
  .story-inner {
    grid-template-columns: 1fr;
    gap: var(--space-8);
    direction: ltr !important;
  }

  .story--image-right .story-image { order: -1; }
}

/* ─── GALLERY ─────────────────────────────────────────────────────────────── */
.gallery-section {
  padding-block: clamp(4rem, 8vw, 8rem);
  background-color: oklch(0.17 0.012 50 / 0.55);
}

.section-header {
  text-align: center;
  margin-bottom: clamp(2rem, 4vw, 4rem);
}

.section-header h2 {
  font-size: clamp(2rem, 3.5vw, 3rem);
  margin-bottom: var(--space-3);
}

.section-header p {
  color: var(--color-ink-muted);
  margin-inline: auto;
}

.gallery-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  grid-template-rows: auto auto;
  gap: var(--space-4);
}

.gallery-item--1 { grid-column: 1; grid-row: 1; }
.gallery-item--2 { grid-column: 2; grid-row: 1 / 3; }
.gallery-item--3 { grid-column: 3; grid-row: 1; }
.gallery-item--4 { grid-column: 1; grid-row: 2; }
.gallery-item--5 { grid-column: 3; grid-row: 2; }
.gallery-item--6 { grid-column: 1 / 4; grid-row: 3; }

.gallery-img-wrap {
  width: 100%;
  height: 100%;
  min-height: 220px;
  border-radius: var(--radius-lg);
  overflow: hidden;
  position: relative;
  cursor: pointer;
}

.gallery-item--2 .gallery-img-wrap { min-height: 460px; }
.gallery-item--2 .gallery-img-wrap { background-color: oklch(0.11 0.01 45); }
.gallery-item--2 .gallery-img { object-fit: cover; object-position: 25% center; }
.gallery-item--6 .gallery-img-wrap { min-height: 200px; }

.gallery-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 250ms var(--ease-out);
}

.gallery-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, oklch(0 0 0 / 0.5), transparent 60%);
  opacity: 0;
  transition: opacity var(--duration-base) var(--ease-out);
}

@media (hover: hover) and (pointer: fine) {
  .gallery-img-wrap:hover .gallery-img { transform: scale(1.07); }
  .gallery-img-wrap:hover .gallery-overlay { opacity: 1; }
  .gallery-img-wrap:hover {
    box-shadow:
      0 0 0 1px oklch(0.75 0.14 85 / 0.35),
      0 0 28px oklch(0.55 0.19 40 / 0.30),
      inset 0 1px 0 oklch(1 0 0 / 0.08);
  }
}

@media (max-width: 768px) {
  .gallery-grid {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: none;
  }

  .gallery-item--1,
  .gallery-item--2,
  .gallery-item--3,
  .gallery-item--4,
  .gallery-item--5,
  .gallery-item--6 {
    grid-column: auto;
    grid-row: auto;
  }

  .gallery-item--2 .gallery-img-wrap { min-height: 220px; }
  .gallery-item--6 .gallery-img-wrap { min-height: 180px; aspect-ratio: 1; }
}

/* ─── MENU ────────────────────────────────────────────────────────────────── */
.menu-section {
  padding-block: clamp(4rem, 8vw, 8rem);
}

.menu-tabs {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
  margin-bottom: var(--space-12);
  border-bottom: 1px solid var(--color-border);
  padding-bottom: 0;
  position: relative;
}

.tab-btn {
  background: none;
  border: none;
  border-bottom: 2px solid transparent;
  padding: var(--space-3) var(--space-4);
  margin-bottom: -1px;
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--color-ink-muted);
  cursor: pointer;
  transition: color var(--duration-base) var(--ease-out),
              border-color var(--duration-base) var(--ease-out);
  white-space: nowrap;
  position: relative;
}

.tab-btn::after { display: none; }

@media (hover: hover) and (pointer: fine) {
  .tab-btn:hover { color: var(--color-ink); }
}

.tab-btn:focus-visible { outline: 2px solid var(--color-primary); outline-offset: 2px; border-radius: 2px; }

.tab-btn[aria-selected="true"] {
  color: var(--color-primary);
  font-weight: 600;
}

/* Sliding indicator — elemento real que se mueve entre tabs */
.tab-indicator {
  position: absolute;
  bottom: -1px;
  left: 0;
  width: 0;
  height: 2px;
  background: var(--color-primary);
  border-radius: 1px;
  box-shadow: 0 0 8px oklch(0.75 0.14 85 / 0.5);
  transition: left 280ms var(--ease-out), width 280ms var(--ease-out);
}

.tab-panel {
  transition: opacity 200ms var(--ease-out), transform 200ms var(--ease-out);
}

.tab-panel.is-hidden { display: none; }

.tab-panel.is-exiting {
  opacity: 0;
  transform: translateY(-4px);
  transition: opacity 150ms var(--ease-out), transform 150ms var(--ease-out);
  pointer-events: none;
}

@starting-style {
  .tab-panel:not(.is-hidden) {
    opacity: 0;
    transform: translateY(8px);
  }
}

.menu-list { display: flex; flex-direction: column; }

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: var(--space-8);
  padding-block: var(--space-5);
  border-bottom: 1px solid var(--color-border);
  position: relative;
}

.menu-item::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, oklch(0.55 0.19 40 / 0.12) 0%, transparent 70%);
  clip-path: inset(0 100% 0 0 round var(--radius-sm));
  transition: clip-path 280ms var(--ease-out);
  pointer-events: none;
}

@media (hover: hover) and (pointer: fine) {
  .menu-item:hover::before {
    clip-path: inset(0 0% 0 0 round var(--radius-sm));
  }
}

.menu-item:last-child { border-bottom: none; }

.menu-item-info { flex: 1; }

.menu-item-info h3 {
  font-family: var(--font-body);
  font-size: 1rem;
  font-weight: 600;
  margin-bottom: var(--space-1);
  letter-spacing: 0;
  line-height: 1.3;
}

.menu-item-info p {
  font-size: 0.875rem;
  color: var(--color-ink-muted);
  max-width: 55ch;
}

.menu-price {
  font-family: var(--font-display);
  font-size: 1.0625rem;
  font-weight: 700;
  color: var(--color-primary);
  white-space: nowrap;
}

.menu-price--consult {
  font-family: var(--font-body);
  font-size: 0.8125rem;
  font-weight: 500;
  color: var(--color-ink-muted);
}

.menu-weight {
  font-weight: 400;
  color: var(--color-ink-muted);
  font-size: 0.875rem;
  margin-left: var(--space-1);
}

.menu-item--featured .menu-item-info h3 { color: var(--color-tertiary); }

.menu-item--consult { opacity: 0.7; }

.badge {
  display: inline-block;
  padding: 0.1em 0.5em;
  background-color: oklch(0.55 0.19 40 / 0.18);
  border: 1px solid oklch(0.55 0.19 40 / 0.4);
  color: var(--color-secondary);
  border-radius: var(--radius-sm);
  font-size: 0.7rem;
  font-weight: 600;
  font-family: var(--font-body);
  letter-spacing: 0.06em;
  text-transform: uppercase;
  vertical-align: middle;
  margin-left: var(--space-2);
}

.menu-note {
  font-size: 0.875rem;
  color: var(--color-secondary);
  padding: var(--space-3) var(--space-4);
  border: 1px solid oklch(0.55 0.19 40 / 0.35);
  background-color: oklch(0.55 0.19 40 / 0.06);
  border-radius: var(--radius-sm);
  margin-bottom: var(--space-8);
}

.menu-subsection { margin-top: var(--space-12); }
.menu-subsection--first { margin-top: 0; }

.menu-subsection-title {
  font-family: var(--font-body);
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-primary);
  margin-bottom: var(--space-2);
  padding-bottom: var(--space-2);
  border-bottom: 1px solid var(--color-border);
}

.menu-list--compact .menu-item {
  padding-block: var(--space-3);
}

.bebidas-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1.5fr;
  gap: var(--space-12);
  align-items: start;
}

.bebidas-vinos { grid-column: 3; }

@media (max-width: 900px) {
  .bebidas-grid {
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }
  .bebidas-vinos { grid-column: 1; }
}

/* ─── LOCATION ────────────────────────────────────────────────────────────── */
.location-section {
  padding-block: clamp(4rem, 8vw, 8rem);
  background-color: oklch(0.17 0.012 50 / 0.55);
}

.location-grid {
  display: grid;
  grid-template-columns: 1fr 1.2fr;
  gap: clamp(3rem, 6vw, 6rem);
  align-items: center;
}

.location-info h2 {
  font-size: clamp(2rem, 3.5vw, 3rem);
  margin-bottom: var(--space-8);
}

.location-details {
  display: flex;
  flex-direction: column;
  gap: var(--space-5);
}

.location-details li {
  display: flex;
  align-items: flex-start;
  gap: var(--space-3);
  color: var(--color-ink-muted);
  font-size: 0.9375rem;
}

.location-details li svg {
  flex-shrink: 0;
  margin-top: 2px;
  color: var(--color-primary);
}

.location-details a {
  color: var(--color-ink-muted);
  text-decoration: none;
  transition: color var(--duration-fast) var(--ease-out);
}

.location-details a:hover { color: var(--color-primary); }

.location-map-iframe {
  aspect-ratio: 4/3;
  width: 100%;
  display: block;
  border-radius: var(--radius-lg);
  overflow: hidden;
  filter: grayscale(0.2) contrast(1.05);
}

@media (max-width: 768px) {
  .location-grid { grid-template-columns: 1fr; }
}

/* ─── EMBER PARTICLES ─────────────────────────────────────────────────────── */
.ember-field {
  position: absolute;
  inset: 0;
  pointer-events: none;
  overflow: hidden;
}

.ember {
  position: absolute;
  bottom: 8%;
  width: 3px;
  height: 3px;
  border-radius: 50%;
  background: var(--color-secondary);
  box-shadow: 0 0 4px var(--color-secondary);
  opacity: 0;
  animation: ember-rise 10s ease-out infinite;
}

@keyframes ember-rise {
  0%   { opacity: 0;    transform: translateY(0)      scale(1);   }
  12%  { opacity: 0.22; }
  65%  { opacity: 0.10; }
  100% { opacity: 0;    transform: translateY(-160px) scale(0.4); }
}

.ember--1 { left: 18%; animation-delay: 0s;    width: 2px; height: 2px; }
.ember--2 { left: 35%; animation-delay: 1.6s;  }
.ember--3 { left: 52%; animation-delay: 3.2s;  width: 2px; height: 2px; }
.ember--4 { left: 68%; animation-delay: 0.8s;  }
.ember--5 { left: 28%; animation-delay: 5.0s;  width: 4px; height: 4px; background: var(--color-primary); box-shadow: 0 0 6px var(--color-primary); }
.ember--6 { left: 44%; animation-delay: 2.4s;  }
.ember--7 { left: 78%; animation-delay: 4.1s;  width: 2px; height: 2px; }
.ember--8 { left: 60%; animation-delay: 6.8s;  }

/* ─── RESERVATIONS ────────────────────────────────────────────────────────── */
.reservations-section {
  padding-block: clamp(9rem, 18vw, 18rem);
  background-color: var(--color-bg);
  background-image: url('/images/gallery-fire.jpg');
  background-size: cover;
  background-position: center 40%;
  position: relative;
  overflow: hidden;
}

.reservations-section::before {
  content: '';
  position: absolute;
  inset: 0;
  background: oklch(0.10 0.01 50 / 0.78);
  pointer-events: none;
}

.reservations-section::after {
  content: 'RESERVA';
  position: absolute;
  font-family: var(--font-display);
  font-size: clamp(6rem, 14vw, 12rem);
  font-weight: 700;
  color: oklch(0.75 0.14 85 / 0.07);
  letter-spacing: -0.03em;
  bottom: -0.1em;
  left: 50%;
  transform: translateX(-50%);
  white-space: nowrap;
  pointer-events: none;
  user-select: none;
}

.reservations-content {
  text-align: center;
  max-width: 560px;
  margin-inline: auto;
  position: relative;
}

.reservations-content h2 {
  font-size: clamp(2.5rem, 4vw, 3.75rem);
  margin-bottom: var(--space-6);
}

.reservations-content p {
  color: var(--color-ink-muted);
  font-size: 1.0625rem;
  line-height: 1.7;
  margin-inline: auto;
  margin-bottom: var(--space-8);
}

/* ─── FOOTER ──────────────────────────────────────────────────────────────── */
.site-footer {
  background-color: var(--color-bg);
  border-top: 1px solid var(--color-border);
  padding-top: clamp(3rem, 6vw, 6rem);
  padding-bottom: var(--space-8);
}

.footer-grid {
  display: grid;
  grid-template-columns: 1.5fr 1fr 1.5fr;
  gap: clamp(2rem, 5vw, 5rem);
  margin-bottom: clamp(3rem, 5vw, 5rem);
}

.footer-brand img { margin-bottom: var(--space-4); }
.footer-brand p {
  font-size: 0.875rem;
  color: var(--color-ink-muted);
  line-height: 1.6;
}

.footer-nav h3,
.footer-contact h3 {
  font-family: var(--font-body);
  font-size: 0.75rem;
  font-weight: 800;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-ink);
  margin-bottom: var(--space-5);
}

.footer-nav ul,
.footer-contact ul {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.footer-nav a,
.footer-contact a {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  font-size: 0.9375rem;
  color: var(--color-ink-muted);
  text-decoration: none;
  transition: color var(--duration-fast) var(--ease-out);
}

.footer-nav a:hover,
.footer-contact a:hover { color: var(--color-primary); }

.footer-contact svg { flex-shrink: 0; opacity: 0.6; }

.footer-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--space-3);
  border-top: 1px solid var(--color-border);
  padding-top: var(--space-6);
  font-size: 0.8125rem;
  color: var(--color-ink-muted);
  opacity: 0.6;
}

@media (max-width: 768px) {
  .footer-grid { grid-template-columns: 1fr; gap: var(--space-8); }
}

/* ─── WhatsApp FAB ────────────────────────────────────────────────────────── */
.whatsapp-fab {
  position: fixed;
  bottom: calc(var(--space-6) + env(safe-area-inset-bottom, 0px));
  right: calc(var(--space-6) + env(safe-area-inset-right, 0px));
  width: 56px;
  height: 56px;
  border-radius: var(--radius-pill);
  background-color: #25D366;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 16px oklch(0 0 0 / 0.35), 0 0 0 0 oklch(0.6 0.18 150 / 0.4);
  z-index: var(--z-sticky);
  transition: transform var(--duration-base) var(--ease-out),
              box-shadow var(--duration-base) var(--ease-out);
  animation: fab-pulse 3s 2s ease-in-out infinite;
}

.whatsapp-fab:active { transform: scale(0.93); }

@media (hover: hover) and (pointer: fine) {
  .whatsapp-fab:hover {
    transform: scale(1.08);
    box-shadow: 0 6px 24px oklch(0 0 0 / 0.4), 0 0 0 8px oklch(0.6 0.18 150 / 0.12);
    animation: none;
  }
}

.whatsapp-fab:focus-visible {
  outline: 2px solid #25D366;
  outline-offset: 3px;
}

@keyframes fab-pulse {
  0%, 100% { box-shadow: 0 4px 16px oklch(0 0 0 / 0.35), 0 0 0 0 oklch(0.6 0.18 150 / 0.4); }
  50% { box-shadow: 0 4px 16px oklch(0 0 0 / 0.35), 0 0 0 10px oklch(0.6 0.18 150 / 0); }
}

@media (min-width: 1024px) {
  .whatsapp-fab { display: none; }
}

/* ─── SKIP LINK ───────────────────────────────────────────────────────────── */
.skip-link {
  position: absolute;
  top: -100%;
  left: var(--space-4);
  background: var(--color-primary);
  color: var(--color-bg);
  padding: 0.5rem 1.25rem;
  border-radius: 0 0 var(--radius-md) var(--radius-md);
  font-size: 0.875rem;
  font-weight: 600;
  font-family: var(--font-body);
  letter-spacing: 0.02em;
  text-decoration: none;
  z-index: 200;
  transition: top 200ms var(--ease-out);
}

.skip-link:focus { top: 0; }

/* ─── STATS STRIP ─────────────────────────────────────────────────────────── */
.stats-strip {
  border-top: 1px solid var(--color-border);
  border-bottom: 1px solid var(--color-border);
  padding-block: clamp(3rem, 6vw, 5.5rem);
  background: oklch(0.155 0.012 50 / 0.55);
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr;
  align-items: center;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.375rem;
  text-align: center;
  padding-inline: var(--space-6);
}

.stat-number {
  font-family: var(--font-display);
  font-size: clamp(3.25rem, 6vw, 5.5rem);
  font-weight: 700;
  line-height: 1;
  letter-spacing: -0.03em;
  color: var(--color-primary);
}

.stat-label {
  font-family: var(--font-body);
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--color-ink-muted);
  max-width: 18ch;
  text-align: center;
}

.stat-divider {
  width: 1px;
  height: 3rem;
  background: var(--color-border);
  flex-shrink: 0;
}

@media (max-width: 768px) {
  .stats-grid {
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
  }
  .stat-divider { display: none; }
  .stat-item { padding-inline: 0; }
}

@media (max-width: 480px) {
  .stats-grid {
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
  }
}

/* ─── MANIFESTO ───────────────────────────────────────────────────────────── */
.manifesto-section {
  padding-block: clamp(8rem, 16vw, 16rem);
  position: relative;
  overflow: hidden;
}

.manifesto-section::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 80% 70% at 50% 50%, oklch(0.55 0.19 40 / 0.10) 0%, transparent 65%),
    radial-gradient(ellipse 60% 50% at 20% 80%, oklch(0.75 0.14 85 / 0.06) 0%, transparent 55%);
  pointer-events: none;
}

.manifesto-text {
  font-family: var(--font-display);
  font-size: clamp(5.5rem, 13vw, 11rem);
  font-weight: 700;
  line-height: 0.87;
  letter-spacing: -0.05em;
  color: var(--color-ink);
  max-width: none;
  text-wrap: balance;
}

@media (prefers-reduced-motion: no-preference) {
  @supports (animation-timeline: view()) {
    .manifesto-text {
      animation: manifesto-arrive linear both;
      animation-timeline: view();
      animation-range: entry 5% entry 55%;
    }
  }
}

@keyframes manifesto-arrive {
  from { opacity: 0.18; transform: scale(0.975) translateY(10px); }
  to   { opacity: 1;    transform: none; }
}

.manifesto-text em {
  font-style: italic;
  color: var(--color-secondary);
}

/* ─── PHILOSOPHY PILLARS ──────────────────────────────────────────────────── */
.pillars-section {
  padding-block: clamp(4rem, 8vw, 8rem);
  background-image:
    radial-gradient(ellipse 70% 60% at 15% 50%, oklch(0.55 0.19 40 / 0.07) 0%, transparent 60%),
    radial-gradient(ellipse 50% 40% at 85% 50%, oklch(0.75 0.14 85 / 0.05) 0%, transparent 55%);
}

.pillars-list {
  display: flex;
  flex-direction: column;
  margin: 0;
  padding: 0;
}

.pillar {
  display: grid;
  grid-template-columns: 1fr 2fr;
  gap: clamp(2rem, 6vw, 6rem);
  align-items: baseline;
  padding-block: clamp(2.5rem, 4.5vw, 4.5rem);
  border-bottom: 1px solid var(--color-border);
}

.pillar:first-child { border-top: 1px solid var(--color-border); }

.pillar-name {
  font-family: var(--font-display);
  font-style: italic;
  font-size: clamp(2rem, 3.5vw, 3rem);
  color: var(--color-primary);
  letter-spacing: -0.02em;
  line-height: 1.0;
  margin: 0;
}

.pillar-desc {
  font-size: 1rem;
  color: var(--color-ink-muted);
  line-height: 1.75;
  max-width: 52ch;
  margin: 0;
}

@media (max-width: 640px) {
  .pillar {
    grid-template-columns: 1fr;
    gap: var(--space-3);
  }
}

/* ─── NAV INNER SHADOW (glass edge refraction) ────────────────────────────── */
.site-nav.is-scrolled {
  box-shadow: inset 0 1px 0 oklch(1 0 0 / 0.05), 0 1px 20px oklch(0 0 0 / 0.18);
}


/* ─── GALLERY CAPTIONS ────────────────────────────────────────────────────── */
.gallery-caption {
  position: absolute;
  bottom: 1rem;
  left: 1rem;
  right: 1rem;
  font-family: var(--font-body);
  font-size: 0.8125rem;
  font-weight: 500;
  color: oklch(1 0 0 / 0.92);
  letter-spacing: 0.06em;
  text-transform: uppercase;
  opacity: 0;
  transform: translateY(6px);
  transition: opacity 200ms var(--ease-out), transform 200ms var(--ease-out);
  pointer-events: none;
}

@media (hover: hover) and (pointer: fine) {
  .gallery-img-wrap:hover .gallery-caption {
    opacity: 1;
    transform: translateY(0);
  }
}

@media (hover: none) {
  .gallery-caption {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ─── PRICE TABULAR NUMS ──────────────────────────────────────────────────── */
.menu-price {
  font-variant-numeric: tabular-nums;
}

/* ─── MENU SUBSECTION GAP (replaces inline style) ────────────────────────── */
.menu-subsection-title--gap { margin-top: 2rem; }

/* ─── INTRO NOTE (bebidas wine section) ──────────────────────────────────── */
.menu-note--intro { margin-bottom: var(--space-6); }

/* ─── FOOTER LEGAL ────────────────────────────────────────────────────────── */
.footer-legal {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  font-size: 0.8125rem;
  color: var(--color-ink-muted);
  opacity: 0.6;
}

.footer-legal a {
  color: inherit;
  text-decoration: none;
  transition: color 150ms var(--ease-out), opacity 150ms var(--ease-out);
}

.footer-legal a:hover { color: var(--color-primary); opacity: 1; }

.footer-legal span { opacity: 0.4; }

/* ═══════════════════════════════════════════════════════════════════════════
   REDESIGN — eliminando AI slop
   ═══════════════════════════════════════════════════════════════════════════ */

/* ─── HERO: full-bleed foto, heading masivo, no más grid 1fr 1fr ─────────── */
.hero {
  min-height: 100dvh;
  justify-content: flex-end;
  padding-top: 0;
}

/* Scrim: oscuro a la izquierda + desde abajo */
.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  z-index: 1;
  background:
    linear-gradient(oklch(0.10 0.012 50 / 0.87), oklch(0.10 0.012 50 / 0.87)),
    linear-gradient(to right, oklch(0.10 0.012 50 / 0.30) 0%, transparent 55%),
    linear-gradient(to top,   oklch(0.10 0.012 50 / 0.70) 0%, transparent 40%);
  pointer-events: none;
}

/* La foto pasa a ser el fondo — cubre todo el hero */
.hero-image {
  position: absolute;
  inset: 0;
  z-index: 0;
  transition: opacity 1200ms var(--ease-out);
}

.hero-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: 60% center;
  aspect-ratio: unset;
  border-radius: 0;
}

.hero-decor { z-index: 2; }

/* Inner: block en vez de grid — texto libre, sin columna derecha */
.hero-inner {
  display: block;
  grid-template-columns: unset;
  padding-block: 0 clamp(4.5rem, 8vw, 8rem);
  padding-top: clamp(14rem, 22vw, 20rem);
  z-index: 3;
}

.hero-text {
  max-width: 54%;
}

/* Heading MASIVO — la fuente trabaja como imagen */
.hero-heading {
  font-size: clamp(3.5rem, 8vw, 6rem);
  line-height: 0.9;
  letter-spacing: -0.04em;
  max-width: none;
  margin-bottom: var(--space-8);
}

.hero-body { max-width: 44ch; }

/* Reemplazar el par btn-primary + btn-outline por primario + text-link */
.hero-actions .btn-outline {
  background: transparent;
  border-color: transparent;
  color: var(--color-ink-muted);
  padding-left: 0;
  padding-right: 0;
  text-decoration: underline;
  text-underline-offset: 4px;
  text-decoration-color: oklch(0.68 0.018 80 / 0.4);
}

@media (hover: hover) and (pointer: fine) {
  .hero-actions .btn-outline:hover {
    background: transparent;
    box-shadow: none;
    color: var(--color-ink);
    text-decoration-color: var(--color-primary);
  }
}



@media (max-width: 900px) {
  .hero-text { max-width: 75%; }
  .hero-heading { font-size: clamp(3.5rem, 10vw, 5.5rem); }
}

@media (max-width: 560px) {
  .hero-text { max-width: 100%; }
  .hero-heading { font-size: clamp(3.5rem, 15vw, 6rem); }
  .hero-inner { padding-bottom: clamp(5rem, 12vw, 8rem); }
}

/* ─── SECTION HEADERS: editorial — left + right, no center ───────────────── */
.section-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  text-align: left;
  gap: var(--space-12);
}

.section-header h2 {
  font-size: clamp(2.75rem, 5.5vw, 5rem);
  line-height: 1.0;
  letter-spacing: -0.03em;
  margin-bottom: 0;
}

.section-header p {
  text-align: right;
  max-width: 22ch;
  flex-shrink: 0;
  margin-inline: 0;
  padding-bottom: 0.15em; /* optical baseline con el heading */
}

@media (max-width: 600px) {
  .section-header { flex-direction: column; align-items: flex-start; gap: var(--space-3); }
  .section-header p { text-align: left; }
}

/* ─── STORY: 60/40 — más imagen, más carácter ────────────────────────────── */
.story--image-left .story-inner  { grid-template-columns: 60% 40%; }
.story--image-right .story-inner { grid-template-columns: 40% 60%; }

/* ─── RESERVACIONES: headline teatral ────────────────────────────────────── */
.reservations-content h2 {
  font-size: clamp(4.5rem, 10vw, 9rem);
  letter-spacing: -0.04em;
  line-height: 0.95;
  margin-bottom: var(--space-6);
}

/* ═══════════════════════════════════════════════════════════════════════════
   SECTION UPGRADES — personality & motion
   ═══════════════════════════════════════════════════════════════════════════ */

/* ─── STATS: glow hover + gradient dividers ───────────────────────────────── */
.stat-item {
  position: relative;
  cursor: default;
  border-radius: var(--radius-md);
  transition: transform 200ms var(--ease-out);
  z-index: 0;
}

.stat-item::after {
  content: '';
  position: absolute;
  inset: -12px;
  border-radius: var(--radius-lg);
  background: radial-gradient(ellipse 90% 90% at 50% 50%, oklch(0.75 0.14 85 / 0.09) 0%, transparent 70%);
  opacity: 0;
  transition: opacity 200ms var(--ease-out);
  pointer-events: none;
  z-index: -1;
}

@media (hover: hover) and (pointer: fine) {
  .stat-item:hover { transform: translateY(-4px); }
  .stat-item:hover::after { opacity: 1; }
  .stat-item:hover .stat-number { color: var(--color-tertiary); }
}

.stat-number { transition: color 150ms var(--ease-out); }

.stat-divider {
  background: linear-gradient(to bottom, transparent 0%, var(--color-border) 30%, var(--color-border) 70%, transparent 100%);
}

/* Stats: override generic translateY reveal — cascade from below */
.stat-item.reveal[data-reveal] {
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 500ms var(--ease-out), transform 500ms var(--ease-out);
}
.stat-item.reveal[data-reveal].is-visible {
  opacity: 1;
  transform: none;
}
.stat-item.reveal[data-reveal-delay="1"] { transition-delay: 80ms; }
.stat-item.reveal[data-reveal-delay="2"] { transition-delay: 160ms; }
.stat-item.reveal[data-reveal-delay="3"] { transition-delay: 240ms; }

/* ─── GALLERY: clip-path reveal en el wrap — el grid nunca colapsa ─────────── */
.gallery-item.reveal[data-reveal] {
  opacity: 1;
  transform: none;
  transition: none;
}

.gallery-item.reveal[data-reveal] .gallery-img-wrap {
  clip-path: inset(7% 7% 7% 7% round var(--radius-lg));
  opacity: 0;
  transition: clip-path 650ms var(--ease-out), opacity 700ms var(--ease-out);
}

.gallery-item.reveal[data-reveal].is-visible .gallery-img-wrap {
  clip-path: inset(0% 0% 0% 0% round var(--radius-lg));
  opacity: 1;
}

.gallery-item[data-reveal-delay="1"] .gallery-img-wrap { transition-delay: 60ms; }
.gallery-item[data-reveal-delay="2"] .gallery-img-wrap { transition-delay: 120ms; }
.gallery-item[data-reveal-delay="3"] .gallery-img-wrap { transition-delay: 180ms; }


/* Ken Burns on the fire image */
@media (prefers-reduced-motion: no-preference) {
  .gallery-item--6 .gallery-img {
    animation: ken-burns 18s ease-in-out infinite alternate;
  }
}

@keyframes ken-burns {
  0%   { transform: scale(1) translateX(0); }
  100% { transform: scale(1.07) translateX(-1.5%); }
}

@media (hover: hover) and (pointer: fine) {
  .gallery-item--6 .gallery-img-wrap:hover .gallery-img {
    animation-play-state: paused;
  }
}

/* ─── PILLARS: index counter + left accent + hover sweep ─────────────────── */
.pillars-list { counter-reset: pillar; }
.pillar { counter-increment: pillar; }

.pillar-name::before {
  content: counter(pillar, decimal-leading-zero);
  display: block;
  font-family: var(--font-display);
  font-size: clamp(3.5rem, 7vw, 6rem);
  font-weight: 700;
  letter-spacing: -0.05em;
  line-height: 0.85;
  color: oklch(0.75 0.14 85 / 0.12);
  margin-bottom: var(--space-4);
  font-style: normal;
  transition: color 200ms var(--ease-out);
}

@media (hover: hover) and (pointer: fine) {
  .pillar:hover .pillar-name::before { color: var(--color-primary); }
}

/* Left accent bar */
.pillar {
  overflow: visible;
  position: relative;
}

.pillar::before {
  content: '';
  position: absolute;
  left: -2px;
  top: 20px;
  bottom: 20px;
  width: 2px;
  background: linear-gradient(to bottom, transparent, var(--color-primary) 30%, var(--color-primary) 70%, transparent);
  transform: scaleY(0);
  transform-origin: top center;
  transition: transform 220ms var(--ease-out);
  pointer-events: none;
  border-radius: 1px;
}

.pillar::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, oklch(0.75 0.14 85 / 0.04) 0%, transparent 45%);
  opacity: 0;
  transition: opacity 220ms var(--ease-out);
  pointer-events: none;
}

@media (hover: hover) and (pointer: fine) {
  .pillar:hover::before { transform: scaleY(1); }
  .pillar:hover::after  { opacity: 1; }
}

/* Independent axis reveal: name from left, desc from right-ish */
.pillar.reveal[data-reveal] {
  opacity: 1;
  transform: none;
  transition: none;
}

.pillar.reveal[data-reveal] .pillar-name {
  opacity: 0;
  transform: translateX(-24px);
  transition: opacity 500ms var(--ease-out), transform 500ms var(--ease-out);
}

.pillar.reveal[data-reveal] .pillar-desc {
  opacity: 0;
  transform: translateX(12px);
  transition: opacity 450ms 120ms var(--ease-out), transform 450ms 120ms var(--ease-out);
}

.pillar.reveal[data-reveal].is-visible .pillar-name,
.pillar.reveal[data-reveal].is-visible .pillar-desc {
  opacity: 1;
  transform: none;
}

.pillar.reveal[data-reveal-delay="1"] .pillar-name { transition-delay: 80ms; }
.pillar.reveal[data-reveal-delay="1"] .pillar-desc  { transition-delay: 210ms; }
.pillar.reveal[data-reveal-delay="2"] .pillar-name  { transition-delay: 160ms; }
.pillar.reveal[data-reveal-delay="2"] .pillar-desc  { transition-delay: 290ms; }
</style>


<script>
/* ─── Nav scroll ──────────────────────────────────────────────────────────── */
const nav = document.getElementById('site-nav');
const onScroll = () => {
  nav?.classList.toggle('is-scrolled', window.scrollY > 40);
};
window.addEventListener('scroll', onScroll, { passive: true });
onScroll();

/* ─── Active nav link ─────────────────────────────────────────────────────── */
const sections = document.querySelectorAll('section[id], footer[id]');
const navLinks = document.querySelectorAll('.nav-link');

const observer = new IntersectionObserver((entries) => {
  for (const entry of entries) {
    if (entry.isIntersecting) {
      navLinks.forEach(link => {
        const href = link.getAttribute('href');
        const match = href === `#${entry.target.id}`;
        link.setAttribute('aria-current', match ? 'true' : 'false');
      });
    }
  }
}, { rootMargin: '-40% 0px -55% 0px' });

sections.forEach(s => observer.observe(s));

/* ─── Mobile nav toggle ───────────────────────────────────────────────────── */
const toggle = document.getElementById('nav-toggle');
const menu = document.getElementById('nav-menu');

toggle?.addEventListener('click', () => {
  const expanded = toggle.getAttribute('aria-expanded') === 'true';
  toggle.setAttribute('aria-expanded', String(!expanded));
  menu?.classList.toggle('is-open', !expanded);
  document.body.style.overflow = !expanded ? 'hidden' : '';
});

menu?.querySelectorAll('a').forEach(link => {
  link.addEventListener('click', () => {
    toggle?.setAttribute('aria-expanded', 'false');
    menu.classList.remove('is-open');
    document.body.style.overflow = '';
  });
});

/* ─── Menu tabs ───────────────────────────────────────────────────────────── */
const tabs = document.querySelectorAll('.tab-btn');
const panels = document.querySelectorAll('.tab-panel');
const tabIndicator = document.querySelector('.tab-indicator');

function updateIndicator(activeTab) {
  if (!tabIndicator) return;
  const container = document.querySelector('.menu-tabs');
  if (!container) return;
  const rect = activeTab.getBoundingClientRect();
  const containerRect = container.getBoundingClientRect();
  tabIndicator.style.left = `${rect.left - containerRect.left}px`;
  tabIndicator.style.width = `${rect.width}px`;
}

const initTab = document.querySelector('.tab-btn[aria-selected="true"]');
if (initTab) requestAnimationFrame(() => updateIndicator(initTab));

window.addEventListener('resize', () => {
  const active = document.querySelector('.tab-btn[aria-selected="true"]');
  if (active) updateIndicator(active);
}, { passive: true });

tabs.forEach(tab => {
  tab.addEventListener('click', () => {
    const targetId = tab.dataset.tab;
    const currentPanel = document.querySelector('.tab-panel:not(.is-hidden):not(.is-exiting)');

    if (currentPanel?.id === `panel-${targetId}`) return;

    tabs.forEach(t => t.setAttribute('aria-selected', 'false'));
    tab.setAttribute('aria-selected', 'true');
    updateIndicator(tab);

    if (currentPanel) {
      currentPanel.classList.add('is-exiting');
      setTimeout(() => {
        currentPanel.classList.remove('is-exiting');
        currentPanel.classList.add('is-hidden');
        document.getElementById(`panel-${targetId}`)?.classList.remove('is-hidden');
      }, 150);
    } else {
      document.getElementById(`panel-${targetId}`)?.classList.remove('is-hidden');
    }
  });
});

/* ─── Reveal on scroll ────────────────────────────────────────────────────── */
const revealEls = document.querySelectorAll('[data-reveal]');

const revealObserver = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add('is-visible');
      revealObserver.unobserve(entry.target);
    }
  });
}, { threshold: 0.12 });

revealEls.forEach(el => revealObserver.observe(el));

/* ─── Stat counter animation ─────────────────────────────────────────────── */
const countEls = document.querySelectorAll('[data-count-to]');

function animateCount(el) {
  const target = parseInt(el.dataset.countTo, 10);
  const prefix = el.dataset.countPrefix || '';
  const suffix = el.dataset.countSuffix || '';
  const duration = 1200;
  const start = performance.now();

  function easeOutCubic(t) { return 1 - Math.pow(1 - t, 3); }

  function tick(now) {
    const elapsed = now - start;
    const progress = Math.min(elapsed / duration, 1);
    const value = Math.round(easeOutCubic(progress) * target);
    el.textContent = prefix + value + suffix;
    if (progress < 1) requestAnimationFrame(tick);
  }

  requestAnimationFrame(tick);
}

const countObserver = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      animateCount(entry.target);
      countObserver.unobserve(entry.target);
    }
  });
}, { threshold: 0.5 });

countEls.forEach(el => countObserver.observe(el));
</script>

</body>
