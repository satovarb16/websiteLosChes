  right: 0;
  z-index: var(--z-sticky);
  transition: background-color var(--duration-base) var(--ease-out),
              backdrop-filter var(--duration-base) var(--ease-out),
              border-color var(--duration-base) var(--ease-out);
  border-bottom: 1px solid transparent;
}

.site-nav.is-scrolled {
  background-color: oklch(0.13 0.01 50 / 0.9);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  border-bottom-color: var(--color-border);
}

.nav-inner {
  display: flex;
  align-items: center;
  gap: var(--space-8);
  padding-block: var(--space-4);
}

.nav-logo img { height: 48px; width: 48px; }

.nav-menu { flex: 1; }

.nav-menu ul {
  display: flex;
  align-items: center;
  gap: var(--space-6);
  justify-content: center;
}

.nav-link {
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-ink-muted);
  text-decoration: none;
  transition: color var(--duration-fast) var(--ease-out);
  position: relative;
}

.nav-link::after {
  content: '';
  position: absolute;
  bottom: -3px;
  left: 0;
  right: 0;
  height: 1px;
  background-color: var(--color-primary);
  transform: scaleX(0);
  transform-origin: left center;
  transition: transform 200ms var(--ease-out);
}

@media (hover: hover) and (pointer: fine) {
  .nav-link:hover { color: var(--color-ink); }
  .nav-link:hover::after { transform: scaleX(1); }
}
.nav-link[aria-current="true"]::after { transform: scaleX(1); }
.nav-link[aria-current="true"] { color: var(--color-ink); }

.nav-cta { white-space: nowrap; }

.nav-toggle {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: var(--space-2);
  margin-left: auto;
  transition: transform 100ms var(--ease-out), opacity 100ms var(--ease-out);
}

.nav-toggle:active { transform: scale(0.88); opacity: 0.7; }

.nav-toggle span {
  display: block;
  width: 24px;
  height: 1.5px;
  background-color: var(--color-ink);
  transition: transform var(--duration-base) var(--ease-out),
              opacity var(--duration-fast) var(--ease-out);
}

.nav-toggle[aria-expanded="true"] span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
.nav-toggle[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
.nav-toggle[aria-expanded="true"] span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

@media (max-width: 768px) {
  /* backdrop-filter would make the fixed bar the containing block for the
     fixed drawer below, collapsing it to the bar's height — solid bar instead */
  .site-nav.is-scrolled {
    background-color: oklch(0.12 0.01 50 / 0.98);
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  .nav-toggle {
    display: flex;
    position: fixed;
    top: var(--space-4);
    right: clamp(1.5rem, 5vw, 5rem);
    z-index: 11;
  }
  .nav-cta { display: none; }

  .nav-menu {
    position: fixed;
    inset: 0;
    top: 73px;
    background-color: var(--color-bg);
    padding: var(--space-8) var(--space-6);
    transform: translateX(100%);
    transition: transform var(--duration-slow) var(--ease-out);
    z-index: var(--z-overlay);
    pointer-events: none;
  }

  .nav-menu.is-open { transform: translateX(0); pointer-events: auto; }

  .nav-menu ul {
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-6);
  }

  /* Fullscreen menu: big serif entries — the drawer becomes a menu card */
  .nav-link {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 400;
    letter-spacing: -0.01em;
    text-transform: none;
    line-height: 1.2;
  }
}


/* ─── HERO ────────────────────────────────────────────────────────────────── */
.hero {
  min-height: 100svh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding-top: 80px;
  position: relative;
  overflow: hidden;
}

.hero-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-16);
  align-items: center;
  padding-block: clamp(4rem, 8vw, 8rem);
  position: relative;
  z-index: 1;
}

.hero-text {
  transition: opacity 600ms var(--ease-out), transform 600ms var(--ease-out);
}

@starting-style {
  .hero-text  { opacity: 0; transform: translateY(20px); }
  .hero-image { opacity: 0; }
}

.hero-eyebrow {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  font-family: var(--font-body);
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-primary);
  margin-bottom: var(--space-4);
}

.hero-eyebrow::before {
  content: '';
  width: 2.5rem;
  height: 1px;
  background: linear-gradient(to right, var(--color-primary), oklch(0.63 0.245 35 / 0.25));
  flex-shrink: 0;
  transform-origin: left center;
}

@media (prefers-reduced-motion: no-preference) {
  .hero-eyebrow::before {
    animation: eyebrow-grow 800ms 250ms var(--ease-out) backwards;
  }
}

@keyframes eyebrow-grow {
  from { transform: scaleX(0); }
}

.hero-heading {
  font-size: clamp(3.5rem, 7vw, 6.5rem);
  font-weight: 700;
  line-height: 1.02;
  letter-spacing: -0.03em;
  margin-bottom: var(--space-6);
  max-width: 12ch;
}

/* Line-mask reveal: cada línea sube desde detrás de su máscara.
   clip-path en vez de overflow:hidden — solo recorta por abajo, los glifos
   italic y los puntos finales pueden desbordar a los costados sin cortarse */
.hero-heading .line {
  display: block;
  clip-path: inset(-0.5em -0.75em 0 -0.75em);
  padding-bottom: 0.08em; /* room for descenders (p, g) under the tight line-height */
  margin-bottom: -0.08em;
}

.hero-heading .line-inner { display: inline-block; }

@media (prefers-reduced-motion: no-preference) {
  .hero-heading .line-inner {
    transform: translateY(115%);
    animation: line-rise 900ms var(--ease-out) forwards;
  }
  .hero-heading .line:nth-child(2) .line-inner { animation-delay: 160ms; }
}

@keyframes line-rise {
  to { transform: translateY(0); }
}

.hero-heading em {
  display: inline-block;
  font-style: italic;
  background: linear-gradient(105deg, var(--color-tertiary) 10%, var(--color-primary) 75%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  padding-bottom: 0.08em; /* keep descenders inside the clipped paint box */
  margin-bottom: -0.08em;
}

.hero-body {
  font-size: clamp(1rem, 1.5vw, 1.125rem);
  color: var(--color-ink-muted);
  line-height: 1.7;
  margin-bottom: var(--space-8);
}

.hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-4);
}

.hero-image {
  position: relative;
  transition: opacity 600ms 120ms var(--ease-out), transform 600ms 120ms var(--ease-out);
}


.hero-img {
  width: 100%;
  aspect-ratio: 3/4;
  object-fit: cover;
  border-radius: var(--radius-lg);
  display: block;
}


@media (max-width: 768px) {
  .hero-inner {
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  .hero-image { order: -1; }

}

/* ─── HERO SCROLL CUE ─────────────────────────────────────────────────────── */
.hero-scroll-cue {
  position: absolute;
  bottom: var(--space-6);
  left: 50%;
  transform: translateX(-50%);
  z-index: 3;
  width: 1px;
  height: 56px;
  overflow: hidden;
  opacity: 0.6;
}

.hero-scroll-cue span {
  display: block;
  width: 100%;
  height: 100%;
  background: linear-gradient(to bottom, transparent, var(--color-ink) 40%, transparent);
  animation: scroll-cue 2.4s var(--ease-in-out) infinite;
}

@keyframes scroll-cue {
  0%   { transform: translateY(-100%); }
  55%  { transform: translateY(100%); }
  100% { transform: translateY(100%); }
}

@media (prefers-reduced-motion: reduce) {
  .hero-scroll-cue { display: none; }
}

@media (max-height: 600px) {
  .hero-scroll-cue { display: none; }
}

/* ─── STORY ───────────────────────────────────────────────────────────────── */
.story {
  padding-block: clamp(4rem, 8vw, 8rem);
}

/* Historia 2 gets extra top breathing room — same layout as Historia 1, needs the silence */
.story--image-right {
  padding-top: clamp(7rem, 14vw, 13rem);
}

.story-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: clamp(3rem, 6vw, 6rem);
  align-items: center;
}

.story-text { }

.story-text h2 {
  font-size: clamp(2rem, 3.5vw, 3.25rem);
  margin-bottom: var(--space-6);
}

.accent       { color: var(--color-primary); font-style: italic; }
.accent-ember { color: var(--color-secondary); font-style: italic; }

.story-text p {
  color: var(--color-ink-muted);
  line-height: 1.75;
  margin-bottom: var(--space-4);
}

/* Pull-quote: entra desde la izquierda, staggered tras el párrafo */
.story-text.reveal[data-reveal] .pull-quote {
  opacity: 0;
  transform: translateX(-20px);
  transition: opacity 550ms 320ms var(--ease-out), transform 550ms 320ms var(--ease-out);
}

.story-text.reveal[data-reveal].is-visible .pull-quote {
  opacity: 1;
  transform: none;
}

.pull-quote {
  position: relative;
  font-family: var(--font-display);
  font-style: italic;
  font-size: clamp(1.25rem, 2.5vw, 1.75rem);
  color: var(--color-primary);
  margin-block: var(--space-8);
  padding-left: var(--space-8);
  quotes: none;
  max-width: 36ch;
}

.pull-quote::before {
  content: '\201C';
  position: absolute;
  left: 0;
  top: -0.5rem;
  font-family: var(--font-display);
  font-size: 5rem;
  line-height: 1;
  color: var(--color-primary);
  opacity: 0.22;
  font-style: normal;
}

.story-img {
  aspect-ratio: 4/5;
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: var(--radius-lg);
  display: block;
}

/* 1px edge highlight — simulates light catching the print's edge */
.story-image {
  position: relative;
}

.story-image::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: var(--radius-lg);
  box-shadow:
    inset 0 1px 0 oklch(1 0 0 / 0.08),
    inset 0 0 0 1px oklch(1 0 0 / 0.04);
  pointer-events: none;
}

/* Story images — fade + ligero scale-up para sensación cinematográfica */
.story-image[data-reveal] {
  opacity: 0;
  transform: scale(0.97);
  transition:
    opacity 700ms var(--ease-out),
    transform 700ms var(--ease-out);
}

.story-image[data-reveal].is-visible {
  opacity: 1;
  transform: scale(1);
}

.story-image[data-reveal-delay="1"] {
  transition-delay: 80ms;
}

@media (max-width: 768px) {
  .story-inner {
    grid-template-columns: 1fr;
    gap: var(--space-8);
    direction: ltr !important;
  }

  .story--image-right .story-image { order: -1; }
}

/* ─── GALLERY ─────────────────────────────────────────────────────────────── */
.gallery-section {
  padding-block: clamp(4rem, 8vw, 8rem);
}

.section-header {
  text-align: center;
  margin-bottom: clamp(2rem, 4vw, 4rem);
}

.section-header h2 {
  font-size: clamp(2rem, 3.5vw, 3rem);
  margin-bottom: var(--space-3);
}

.section-header p {
  color: var(--color-ink-muted);
  margin-inline: auto;
}

.gallery-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  grid-template-rows: auto auto;
  gap: var(--space-4);
}

.gallery-item--1 { grid-column: 1; grid-row: 1; }
.gallery-item--2 { grid-column: 2; grid-row: 1 / 3; }
.gallery-item--3 { grid-column: 3; grid-row: 1; }
.gallery-item--4 { grid-column: 1; grid-row: 2; }
.gallery-item--5 { grid-column: 3; grid-row: 2; }

.gallery-img-wrap {
  width: 100%;
  height: 100%;
  min-height: 220px;
  border-radius: var(--radius-lg);
  overflow: hidden;
  position: relative;
  cursor: pointer;
}

.gallery-item--2 .gallery-img-wrap { min-height: 460px; }
.gallery-item--2 .gallery-img-wrap { background-color: oklch(0.11 0.01 45); }
.gallery-item--2 .gallery-img { object-fit: cover; object-position: 25% center; }

.gallery-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 250ms var(--ease-out);
}

.gallery-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, oklch(0 0 0 / 0.5), transparent 60%);
  opacity: 0;
  transition: opacity var(--duration-base) var(--ease-out);
}

.gallery-img-wrap::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  box-shadow:
    inset 0 1px 0 oklch(1 0 0 / 0.08),
    inset 0 0 0 1px oklch(1 0 0 / 0.04);
  pointer-events: none;
}

@media (hover: hover) and (pointer: fine) {
  .gallery-img-wrap:hover .gallery-img { transform: scale(1.07); }
  .gallery-img-wrap:hover .gallery-overlay { opacity: 1; }
  .gallery-img-wrap:hover {
    box-shadow:
      0 0 0 1px oklch(0.63 0.245 35 /0.35),
      0 0 28px oklch(0.55 0.19 40 / 0.30),
      inset 0 1px 0 oklch(1 0 0 / 0.08);
  }
}

@media (max-width: 768px) {
  .gallery-grid {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: none;
  }

  .gallery-item--1,
  .gallery-item--2,
  .gallery-item--3,
  .gallery-item--4,
  .gallery-item--5 {
    grid-column: auto;
    grid-row: auto;
  }

  .gallery-item--2 .gallery-img-wrap { min-height: 220px; }
}

/* ─── MENU ────────────────────────────────────────────────────────────────── */
.menu-section {
  padding-block: clamp(4rem, 8vw, 8rem);
  background: oklch(0.07 0.010 40 / 0.82);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-top: 1px solid var(--color-border);
  border-bottom: 1px solid var(--color-border);
}

.menu-tabs {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
  margin-bottom: var(--space-12);
  border-bottom: 1px solid var(--color-border);
  padding-bottom: 0;
  position: relative;
}

@media (max-width: 768px) {
  .menu-tabs {
    flex-wrap: nowrap;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    gap: var(--space-1);
  }
  .menu-tabs::-webkit-scrollbar { display: none; }
  .tab-btn { flex: none; }
}

.tab-btn {
  background: none;
  border: none;
  border-bottom: 2px solid transparent;
  padding: var(--space-3) var(--space-4);
  margin-bottom: -1px;
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-ink-muted);
  cursor: pointer;
  transition: color var(--duration-base) var(--ease-out),
              border-color var(--duration-base) var(--ease-out),
              transform 120ms var(--ease-out);
  white-space: nowrap;
  position: relative;
  flex: 1;
  text-align: center;
}

.tab-btn:active { transform: scale(0.95); }

.tab-btn::after { display: none; }

@media (hover: hover) and (pointer: fine) {
  .tab-btn:hover { color: var(--color-ink); }
}

.tab-btn:focus-visible { outline: 2px solid var(--color-primary); outline-offset: 2px; border-radius: 2px; }

.tab-btn[aria-selected="true"] {
  color: var(--color-primary);
  font-weight: 600;
}

/* Sliding indicator — elemento real que se mueve entre tabs */
.tab-indicator {
  position: absolute;
  bottom: -1px;
  left: 0;
  width: 0;
  height: 2px;
  background: var(--color-primary);
  border-radius: 1px;
  box-shadow: 0 0 8px oklch(0.63 0.245 35 /0.5);
  transition: left 280ms var(--ease-out), width 280ms var(--ease-out);
}

.tab-panel {
  transition: opacity 200ms var(--ease-out), transform 200ms var(--ease-out);
}

.tab-panel.is-hidden { display: none; }

.tab-panel.is-exiting {
  opacity: 0;
  transform: translateY(-4px);
  transition: opacity 150ms var(--ease-out), transform 150ms var(--ease-out);
  pointer-events: none;
}

@keyframes panel-enter {
  from { opacity: 0; transform: translateY(8px); }
  to   { opacity: 1; transform: translateY(0); }
}

.tab-panel.is-entering {
  animation: panel-enter 200ms var(--ease-out) forwards;
}

@starting-style {
  .tab-panel:not(.is-hidden) {
    opacity: 0;
    transform: translateY(8px);
  }
}

.menu-list { display: flex; flex-direction: column; }

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: var(--space-3);
  padding-block: var(--space-5);
  border-bottom: 1px solid var(--color-border);
  position: relative;
}

.menu-item::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, oklch(0.55 0.19 40 / 0.12) 0%, transparent 70%);
  clip-path: inset(0 100% 0 0 round var(--radius-sm));
  transition: clip-path 280ms var(--ease-out);
  pointer-events: none;
}

@media (hover: hover) and (pointer: fine) {
  .menu-item:hover::before {
    clip-path: inset(0 0% 0 0 round var(--radius-sm));
  }
}

.menu-item:last-child { border-bottom: none; }

.menu-item-info { flex: 1; }

.menu-item-info h3 {
  display: flex;
  align-items: baseline;
  font-family: var(--font-body);
  font-size: 1rem;
  font-weight: 600;
  margin-bottom: var(--space-1);
  letter-spacing: 0;
  line-height: 1.3;
}

/* Dot leader — classic menu typography connecting dish to price */
.menu-item-info h3::after {
  content: '';
  flex: 1;
  min-width: var(--space-4);
  margin-inline-start: 0.6em;
  border-bottom: 1px dotted oklch(0.45 0.03 50 / 0.7);
  transform: translateY(-0.3em);
}

.menu-item-info p {
  font-size: 0.875rem;
  color: var(--color-ink-muted);
  max-width: 55ch;
}

.menu-price {
  font-family: var(--font-display);
  font-size: 1.0625rem;
  font-weight: 400;
  color: var(--color-ink);
  white-space: nowrap;
  transition: color var(--duration-fast) var(--ease-out);
}

@media (hover: hover) and (pointer: fine) {
  .menu-item:hover .menu-price { color: var(--color-primary); }
}

.menu-price--consult {
  font-family: var(--font-body);
  font-size: 0.8125rem;
  font-weight: 500;
  color: var(--color-ink-muted);
}

.menu-weight {
  font-weight: 400;
  color: var(--color-ink-muted);
  font-size: 0.875rem;
  margin-left: var(--space-1);
}

.menu-item--featured .menu-item-info h3 { color: var(--color-tertiary); }

.menu-item--consult { opacity: 0.7; }

.badge {
  display: inline-block;
  padding: 0.1em 0.5em;
  background-color: oklch(0.55 0.19 40 / 0.18);
  border: 1px solid oklch(0.55 0.19 40 / 0.4);
  color: var(--color-secondary);
  border-radius: var(--radius-sm);
  font-size: 0.7rem;
  font-weight: 600;
  font-family: var(--font-body);
  letter-spacing: 0.06em;
  text-transform: uppercase;
  vertical-align: middle;
  margin-left: var(--space-2);
}

.menu-note {
  font-size: 0.875rem;
  color: var(--color-secondary);
  padding: var(--space-3) var(--space-4);
  border: 1px solid oklch(0.55 0.19 40 / 0.35);
  background-color: oklch(0.55 0.19 40 / 0.06);
  border-radius: var(--radius-sm);
  margin-bottom: var(--space-8);
}

.menu-subsection { margin-top: var(--space-12); }
.menu-subsection--first { margin-top: 0; }

.platos-grid {
  display: grid;
  grid-template-columns: 1fr 300px;
  gap: clamp(2rem, 5vw, 5rem);
  align-items: start;
}

.platos-side {
  border-left: 1px solid var(--color-border);
  padding-left: clamp(2rem, 5vw, 5rem);
}

@media (max-width: 768px) {
  .platos-grid {
    grid-template-columns: 1fr;
  }
  .platos-side {
    border-left: none;
    border-top: 1px solid var(--color-border);
    padding-left: 0;
    padding-top: var(--space-12);
  }
}

.menu-subsection-title {
  font-family: var(--font-body);
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-primary);
  margin-bottom: var(--space-2);
  padding-bottom: var(--space-2);
  border-bottom: 1px solid var(--color-border);
}

.menu-list--compact .menu-item {
  padding-block: var(--space-3);
}

.menu-list--compact .menu-item > span:first-child {
  flex: 1;
  display: flex;
  align-items: baseline;
  font-size: 0.9375rem;
}

.menu-list--compact .menu-item > span:first-child::after {
  content: '';
  flex: 1;
  min-width: var(--space-4);
  margin-inline-start: 0.6em;
  border-bottom: 1px dotted oklch(0.45 0.03 50 / 0.7);
  transform: translateY(-0.3em);
}

.bebidas-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1.5fr;
  gap: var(--space-12);
  align-items: start;
}

.bebidas-vinos { grid-column: 3; }

@media (max-width: 900px) {
  .bebidas-grid {
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }
  .bebidas-vinos { grid-column: 1; }
}

/* ─── LOCATION ────────────────────────────────────────────────────────────── */
.location-section {
  padding-block: clamp(4rem, 8vw, 8rem);
}

.location-grid {
  display: grid;
  grid-template-columns: 1fr 1.2fr;
  gap: clamp(3rem, 6vw, 6rem);
  align-items: center;
}

.location-info h2 {
  font-size: clamp(2rem, 3.5vw, 3rem);
  margin-bottom: var(--space-8);
}

.location-details {
  display: flex;
  flex-direction: column;
  gap: var(--space-5);
}

.location-details li {
  display: flex;
  align-items: flex-start;
  gap: var(--space-3);
  color: var(--color-ink-muted);
  font-size: 0.9375rem;
}

.location-details li svg {
  flex-shrink: 0;
  margin-top: 2px;
  color: var(--color-primary);
}

.hours-schedule {
  display: flex;
  flex-direction: column;
}

.hours-list {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-1);
  margin: 0;
  padding: 0;
}

.hours-row {
  display: flex;
  gap: var(--space-3);
}

.hours-row dt {
  min-width: 7rem;
  font-weight: 500;
  color: var(--color-ink);
  display: flex;
  align-items: center;
  gap: var(--space-2);
  flex-wrap: wrap;
}

.hours-row dd {
  margin: 0;
  display: flex;
  align-items: center;
  gap: var(--space-2);
  flex-wrap: wrap;
}

.hours-row--closed dt,
.hours-row--closed dd {
  color: var(--color-ink-muted);
  opacity: 0.5;
}

/* Today's row glows like an ember */
.hours-row.is-today dt,
.hours-row.is-today dd {
  color: var(--color-ink);
  font-weight: 600;
  opacity: 1;
}

.hours-row.is-today dt::before {
  content: '';
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--color-primary);
  box-shadow: 0 0 8px oklch(0.63 0.245 35 / 0.7);
  flex-shrink: 0;
}


.location-details a {
  color: var(--color-ink-muted);
  text-decoration: none;
  transition: color var(--duration-fast) var(--ease-out);
}

@media (hover: hover) and (pointer: fine) {
  .location-details a:hover { color: var(--color-primary); }
}

.location-map {
  border-radius: var(--radius-lg);
  overflow: hidden;
  border: 1px solid var(--color-border);
  box-shadow: inset 0 1px 0 oklch(1 0 0 / 0.05), 0 12px 40px oklch(0 0 0 / 0.35);
}

/* Invert flips the light Google embed into the site's dark palette */
.location-map-iframe {
  aspect-ratio: 4/3;
  width: 100%;
  display: block;
  filter: invert(0.89) hue-rotate(180deg) saturate(0.4) contrast(0.92) brightness(0.95);
}

@media (max-width: 768px) {
  .location-grid { grid-template-columns: 1fr; }
}

/* ─── EMBER PARTICLES ─────────────────────────────────────────────────────── */
.ember-field {
  position: absolute;
  inset: 0;
  pointer-events: none;
  overflow: hidden;
}

.ember {
  position: absolute;
  bottom: 8%;
  width: 3px;
  height: 3px;
  border-radius: 50%;
  background: var(--color-secondary);
  box-shadow: 0 0 4px var(--color-secondary);
  opacity: 0;
  animation: ember-rise 10s ease-out infinite;
}

@media (prefers-reduced-motion: reduce) {
  .ember { animation: none; opacity: 0; }
}

@keyframes ember-rise {
  0%   { opacity: 0;    transform: translateY(0)      translateX(0)    scale(1);    }
  10%  { opacity: 0.26; }
  60%  { opacity: 0.12; transform: translateY(-130px)  translateX(7px)  scale(0.65); }
  100% { opacity: 0;    transform: translateY(-215px)  translateX(16px) scale(0.28); }
}

.ember--1 { left: 18%; animation-delay: 0s;    width: 2px; height: 2px; animation-duration: 9s; }
.ember--2 { left: 35%; animation-delay: 1.6s;  animation-duration: 11.5s; }
.ember--3 { left: 52%; animation-delay: 3.2s;  width: 2px; height: 2px; animation-duration: 8.5s; }
.ember--4 { left: 68%; animation-delay: 0.8s;  animation-duration: 12s; }
.ember--5 { left: 28%; animation-delay: 5.0s;  width: 4px; height: 4px; background: var(--color-primary); box-shadow: 0 0 6px var(--color-primary); animation-duration: 14s; }
.ember--6 { left: 44%; animation-delay: 2.4s;  animation-duration: 10.5s; }
.ember--7 { left: 78%; animation-delay: 4.1s;  width: 2px; height: 2px; animation-duration: 7.5s; }
.ember--8 { left: 60%; animation-delay: 6.8s;  animation-duration: 13s; }

/* ─── SECTION DIVIDER ────────────────────────────────────────────────────── */
.section-divider {
  border: none;
  height: 1px;
  background: linear-gradient(to right, transparent, var(--color-border) 18%, var(--color-border) 82%, transparent);
  margin: 0;
}

/* ─── RESERVATIONS ────────────────────────────────────────────────────────── */
.reservations-section {
  padding-block: clamp(9rem, 18vw, 18rem);
  background-color: var(--color-bg);
  background-image: url('/images/gallery-fire.jpg');
  background-size: cover;
  background-position: center 40%;
  position: relative;
  overflow: hidden;
}

.reservations-section::before {
  content: '';
  position: absolute;
  inset: 0;
  background: oklch(0.10 0.01 50 / 0.78);
  pointer-events: none;
}

.reservations-section::after {
  content: none;
}

.reservations-content {
  text-align: center;
  max-width: 560px;
  margin-inline: auto;
  position: relative;
}

.reservations-content h2 {
  font-size: clamp(2.5rem, 4vw, 3.75rem);
  margin-bottom: var(--space-6);
}

.reservations-content p {
  color: var(--color-ink-muted);
  font-size: 1.0625rem;
  line-height: 1.7;
  margin-inline: auto;
  margin-bottom: var(--space-8);
}

/* WhatsApp CTA: pulso suave en idle para invitar al click */
@media (prefers-reduced-motion: no-preference) {
  .reservations-content .btn-whatsapp {
    animation: whatsapp-pulse 3.8s ease-in-out infinite;
  }
}

@media (hover: hover) and (pointer: fine) {
  .reservations-content .btn-whatsapp:hover {
    animation-play-state: paused;
  }
}

@keyframes whatsapp-pulse {
  0%, 100% { box-shadow: 0 0 0 0 oklch(0.60 0.18 150 / 0); }
  50%       { box-shadow: 0 0 16px 4px oklch(0.60 0.18 150 / 0.30), 0 0 36px 8px oklch(0.55 0.19 40 / 0.14); }
}

/* ─── FOOTER ──────────────────────────────────────────────────────────────── */
.site-footer {
  background-color: var(--color-bg);
  border-top: 1px solid var(--color-border);
  padding-top: clamp(3rem, 6vw, 6rem);
  padding-bottom: var(--space-8);
}

.footer-grid {
  display: grid;
  grid-template-columns: 1.5fr 1fr 1.5fr;
  gap: clamp(2rem, 5vw, 5rem);
  margin-bottom: clamp(3rem, 5vw, 5rem);
}

.footer-brand img { margin-bottom: var(--space-4); }
.footer-brand p {
  font-size: 0.875rem;
  color: var(--color-ink-muted);
  line-height: 1.6;
}

.footer-nav h3,
.footer-contact h3 {
  font-family: var(--font-body);
  font-size: 0.75rem;
  font-weight: 800;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-ink);
  margin-bottom: var(--space-5);
}

.footer-nav ul,
.footer-contact ul {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.footer-nav a,
.footer-contact a {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  font-size: 0.9375rem;
  color: var(--color-ink-muted);
  text-decoration: none;
  transition: color var(--duration-fast) var(--ease-out);
}

@media (hover: hover) and (pointer: fine) {
  .footer-nav a:hover,
  .footer-contact a:hover { color: var(--color-primary); }
}

.footer-contact svg { flex-shrink: 0; opacity: 0.6; }

/* Giant serif signature — brand presence as a closing gesture */
.footer-wordmark {
  font-family: var(--font-display);
  font-style: italic;
  font-weight: 700;
  font-size: clamp(4rem, 15vw, 13rem);
  line-height: 0.85;
  letter-spacing: -0.04em;
  text-align: center;
  color: oklch(0.88 0.018 80 / 0.05);
  max-width: none;
  user-select: none;
  pointer-events: none;
  margin-bottom: calc(var(--space-8) * -0.5);
  text-wrap: nowrap;
  overflow: hidden;
}

.footer-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--space-3);
  border-top: 1px solid var(--color-border);
  padding-top: var(--space-6);
  font-size: 0.8125rem;
  color: var(--color-ink-muted);
  opacity: 0.6;
}

@media (max-width: 768px) {
  .footer-grid { grid-template-columns: 1fr; gap: var(--space-8); }
}

/* ─── WhatsApp FAB ────────────────────────────────────────────────────────── */
.whatsapp-fab {
  position: fixed;
  bottom: calc(var(--space-6) + env(safe-area-inset-bottom, 0px));
  right: calc(var(--space-6) + env(safe-area-inset-right, 0px));
  width: 56px;
  height: 56px;
  border-radius: var(--radius-pill);
  background-color: #25D366;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 16px oklch(0 0 0 / 0.35), 0 0 0 0 oklch(0.6 0.18 150 / 0.4);
  z-index: var(--z-sticky);
  transition: transform var(--duration-base) var(--ease-out),
              box-shadow var(--duration-base) var(--ease-out);
  animation: fab-pulse 3s 2s ease-in-out infinite;
}

.whatsapp-fab:active { transform: scale(0.93); }

@media (hover: hover) and (pointer: fine) {
  .whatsapp-fab:hover {
    transform: scale(1.08);
    box-shadow: 0 6px 24px oklch(0 0 0 / 0.4), 0 0 0 8px oklch(0.6 0.18 150 / 0.12);
    animation: none;
  }
}

.whatsapp-fab:focus-visible {
  outline: 2px solid #25D366;
  outline-offset: 3px;
}

@keyframes fab-pulse {
  0%, 100% { box-shadow: 0 4px 16px oklch(0 0 0 / 0.35), 0 0 0 0 oklch(0.6 0.18 150 / 0.4); }
  50% { box-shadow: 0 4px 16px oklch(0 0 0 / 0.35), 0 0 0 10px oklch(0.6 0.18 150 / 0); }
}

@media (min-width: 1024px) {
  .whatsapp-fab { display: none; }
}

/* ─── SKIP LINK ───────────────────────────────────────────────────────────── */
.skip-link {
  position: absolute;
  top: -100%;
  left: var(--space-4);
  background: var(--color-primary);
  color: var(--color-bg);
  padding: 0.5rem 1.25rem;
  border-radius: 0 0 var(--radius-md) var(--radius-md);
  font-size: 0.875rem;
  font-weight: 600;
  font-family: var(--font-body);
  letter-spacing: 0.02em;
  text-decoration: none;
  z-index: 200;
  transition: top 200ms var(--ease-out);
}

.skip-link:focus { top: 0; }

/* ─── STATS STRIP ─────────────────────────────────────────────────────────── */
.stats-strip {
  border-top: 1px solid var(--color-border);
  border-bottom: 1px solid var(--color-border);
  padding-block: clamp(3rem, 6vw, 5.5rem);
  background: oklch(0.07 0.010 40 / 0.82);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr;
  align-items: center;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.375rem;
  text-align: center;
  padding-inline: var(--space-6);
}

.stat-number {
  font-family: var(--font-display);
  font-size: clamp(3.25rem, 6vw, 5.5rem);
  font-weight: 700;
  line-height: 1;
  letter-spacing: -0.03em;
  color: var(--color-primary);
}

.stat-label {
  font-family: var(--font-body);
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--color-ink-muted);
  max-width: 18ch;
  text-align: center;
}

.stat-divider {
  width: 1px;
  height: 3rem;
  background: var(--color-border);
  flex-shrink: 0;
}

@media (max-width: 768px) {
  .stats-grid {
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
  }
  .stat-divider { display: none; }
  .stat-item { padding-inline: 0; }
}

@media (max-width: 480px) {
  .stats-grid {
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
  }
}

.story-manifesto-header {
  padding-top: clamp(4rem, 8vw, 8rem);
  padding-bottom: clamp(2.5rem, 5vw, 5rem);
}

/* ─── MANIFESTO ───────────────────────────────────────────────────────────── */
.manifesto-text {
  font-family: var(--font-display);
  font-size: clamp(4rem, 9vw, 7.5rem);
  font-weight: 700;
  line-height: 0.9;
  letter-spacing: -0.04em;
  color: var(--color-ink);
  max-width: none;
  text-wrap: balance;
}

@media (prefers-reduced-motion: no-preference) {
  @supports (animation-timeline: view()) {
    .manifesto-text {
      animation: manifesto-arrive linear both;
      animation-timeline: view();
      animation-range: entry 5% entry 55%;
    }
  }
}

@keyframes manifesto-arrive {
  from { opacity: 0.18; transform: scale(0.975) translateY(10px); }
  to   { opacity: 1;    transform: none; }
}

.manifesto-text em {
  font-style: italic;
  color: var(--color-secondary);
  display: inline-block;
}

/* La palabra clave entra desde la derecha, con su propio ritmo */
@media (prefers-reduced-motion: no-preference) {
  @supports (animation-timeline: view()) {
    .manifesto-text em {
      animation: manifesto-em linear both;
      animation-timeline: view();
      animation-range: entry 22% entry 68%;
    }
  }
}

@keyframes manifesto-em {
  from { opacity: 0.05; transform: translateX(20px); }
  to   { opacity: 1;    transform: none; }
}

/* ─── PHILOSOPHY PILLARS — removed; replaced by doneness section ─────────── */

/* ─── NAV INNER SHADOW (glass edge refraction) ────────────────────────────── */
.site-nav.is-scrolled {
  box-shadow: inset 0 1px 0 oklch(1 0 0 / 0.05), 0 1px 20px oklch(0 0 0 / 0.18);
}


/* ─── GALLERY CAPTIONS ────────────────────────────────────────────────────── */
.gallery-caption {
  position: absolute;
  bottom: 1rem;
  left: 1rem;
  right: 1rem;
  font-family: var(--font-body);
  font-size: 0.8125rem;
  font-weight: 500;
  color: oklch(1 0 0 / 0.92);
  letter-spacing: 0.06em;
  text-transform: uppercase;
  opacity: 0;
  transform: translateY(6px);
  transition: opacity 200ms var(--ease-out), transform 200ms var(--ease-out);
  pointer-events: none;
}

@media (hover: hover) and (pointer: fine) {
  .gallery-img-wrap:hover .gallery-caption {
    opacity: 1;
    transform: translateY(0);
  }
}

@media (hover: none) {
  .gallery-overlay { opacity: 0.8; }
  .gallery-caption { opacity: 1; transform: translateY(0); }
}

/* ─── PRICE TABULAR NUMS ──────────────────────────────────────────────────── */
.menu-price {
  font-variant-numeric: tabular-nums;
}

/* ─── MENU SUBSECTION GAP (replaces inline style) ────────────────────────── */
.menu-subsection-title--gap { margin-top: 2rem; }

/* ─── INTRO NOTE (bebidas wine section) ──────────────────────────────────── */
.menu-note--intro { margin-bottom: var(--space-6); }

/* ─── FOOTER LEGAL ────────────────────────────────────────────────────────── */
.footer-legal {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  font-size: 0.8125rem;
  color: var(--color-ink-muted);
  opacity: 0.6;
}

.footer-legal a {
  color: inherit;
  text-decoration: none;
  transition: color 150ms var(--ease-out), opacity 150ms var(--ease-out);
}

@media (hover: hover) and (pointer: fine) {
  .footer-legal a:hover { color: var(--color-primary); opacity: 1; }
}

.footer-legal span { opacity: 0.4; }

/* ═══════════════════════════════════════════════════════════════════════════
   REDESIGN — eliminando AI slop
   ═══════════════════════════════════════════════════════════════════════════ */

/* ─── HERO: full-bleed foto, heading masivo, no más grid 1fr 1fr ─────────── */
.hero {
  min-height: 100dvh;
  justify-content: flex-end;
  padding-top: 0;
}

/* Scrim direccional: denso bajo el texto, abre hacia la derecha para que la foto respire */
.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  z-index: 1;
  background:
    linear-gradient(to right,
      oklch(0.10 0.012 50 / 0.94) 0%,
      oklch(0.10 0.012 50 / 0.82) 38%,
      oklch(0.10 0.012 50 / 0.48) 68%,
      oklch(0.10 0.012 50 / 0.58) 100%),
    linear-gradient(to top,    oklch(0.10 0.012 50 / 0.88) 0%, transparent 38%),
    linear-gradient(to bottom, oklch(0.10 0.012 50 / 0.55) 0%, transparent 22%);
  pointer-events: none;
}

@media (max-width: 768px) {
  /* En mobile el texto ocupa todo el ancho — scrim uniforme para contraste AA */
  .hero::before {
    background:
      linear-gradient(oklch(0.10 0.012 50 / 0.82), oklch(0.10 0.012 50 / 0.82)),
      linear-gradient(to top, oklch(0.10 0.012 50 / 0.85) 0%, transparent 45%);
  }
}

/* La foto pasa a ser el fondo — cubre todo el hero */
.hero-image {
  position: absolute;
  inset: 0;
  z-index: 0;
  transition: opacity 1200ms var(--ease-out);
}

.hero-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: 60% center;
  aspect-ratio: unset;
  border-radius: 0;
}

.hero-decor { z-index: 2; }

/* Inner: block en vez de grid — texto libre, sin columna derecha */
.hero-inner {
  display: block;
  grid-template-columns: unset;
  padding-block: 0 clamp(4.5rem, 8vw, 8rem);
  padding-top: clamp(5rem, 8vw, 8rem);
  z-index: 3;
}

.hero-text {
  max-width: 54%;
}

/* Heading MASIVO — la fuente trabaja como imagen */
.hero-heading {
  font-size: clamp(3.5rem, 8vw, 6rem);
  line-height: 0.9;
  letter-spacing: -0.04em;
  max-width: none;
  margin-bottom: var(--space-8);
}

.hero-body { max-width: 44ch; }

/* Reemplazar el par btn-primary + btn-outline por primario + text-link */
.hero-actions .btn-outline {
  background: transparent;
  border-color: transparent;
  color: var(--color-ink-muted);
  padding-left: 0;
  padding-right: 0;
  text-decoration: underline;
  text-underline-offset: 4px;
  text-decoration-color: oklch(0.68 0.018 80 / 0.4);
}

@media (hover: hover) and (pointer: fine) {
  .hero-actions .btn-outline:hover {
    background: transparent;
    box-shadow: none;
    color: var(--color-ink);
    text-decoration-color: var(--color-primary);
  }
}



@media (max-width: 900px) {
  .hero-text { max-width: 75%; }
  .hero-heading { font-size: clamp(3.5rem, 10vw, 5.5rem); }
}

@media (max-width: 560px) {
  .hero-text { max-width: 100%; }
  .hero-heading { font-size: clamp(3.5rem, 15vw, 6rem); }
  .hero-inner { padding-bottom: clamp(5rem, 12vw, 8rem); }
}

/* ─── SECTION HEADERS: editorial — left + right, no center ───────────────── */
.section-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  text-align: left;
  gap: var(--space-12);
}

.section-header h2 {
  font-size: clamp(2.75rem, 5.5vw, 5rem);
  line-height: 1.0;
  letter-spacing: -0.03em;
  margin-bottom: 0;
}

.section-header p {
  text-align: right;
  max-width: 22ch;
  flex-shrink: 0;
  margin-inline: 0;
  padding-bottom: 0.15em; /* optical baseline con el heading */
}

@media (max-width: 600px) {
  .section-header { flex-direction: column; align-items: flex-start; gap: var(--space-3); }
  .section-header p { text-align: left; }
}

/* ─── STORY: 60/40 — más imagen, más carácter ────────────────────────────── */
.story--image-left .story-inner  { grid-template-columns: 60% 40%; }
.story--image-right .story-inner { grid-template-columns: 40% 60%; }

/* ─── RESERVACIONES: headline teatral ────────────────────────────────────── */
.reservations-content h2 {
  font-size: clamp(4.5rem, 10vw, 9rem);
  letter-spacing: -0.04em;
  line-height: 0.95;
  margin-bottom: var(--space-6);
}

.reservations-content h2 em {
  font-style: italic;
  color: var(--color-primary);
}

/* ═══════════════════════════════════════════════════════════════════════════
   SECTION UPGRADES — personality & motion
   ═══════════════════════════════════════════════════════════════════════════ */

/* ─── STATS: glow hover + gradient dividers ───────────────────────────────── */
.stat-item {
  position: relative;
  cursor: default;
  border-radius: var(--radius-md);
  transition: transform 200ms var(--ease-out);
  z-index: 0;
}

.stat-item::after {
  content: '';
  position: absolute;
  inset: -72px;
  background: radial-gradient(ellipse 45% 50% at 50% 50%, oklch(0.63 0.245 35 / 0.18) 0%, transparent 100%);
  opacity: 0;
  transition: opacity 200ms var(--ease-out);
  pointer-events: none;
  z-index: -1;
}

@media (hover: hover) and (pointer: fine) {
