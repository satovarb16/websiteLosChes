---
import '../styles/global.css';
import { Image } from 'astro:assets';
const whatsappNumber = "+519547707573";
const whatsappMsg = encodeURIComponent("Hola, quiero hacer una reserva en Los Ches.");
const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${whatsappMsg}`;
---

<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="description" content="Los Ches — Parrilla y kamado en Lima. Cortes Angus importados, parrillas para compartir y el sabor de una reunión familiar." />
  <meta property="og:title" content="Los Ches — Grill &amp; Meals" />
  <meta property="og:description" content="Cortes Angus argentinos y americanos al kamado, parrillas para compartir, en Lima, Perú." />
  <meta property="og:image" content="/images/hero.png" />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content="/images/hero.png" />
  <link rel="icon" type="image/svg+xml" href="/logo.svg" />
  <title>Los Ches — Grill & Meals</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Libre+Caslon+Text:ital,wght@0,400;0,700;1,400&family=Hanken+Grotesk:wght@300;400;500;600&display=swap" />
</head>

<body>

<div class="mesh-bg" aria-hidden="true">
  <span class="mesh-blob mesh--1"></span>
  <span class="mesh-blob mesh--2"></span>
  <span class="mesh-blob mesh--3"></span>
</div>

<div class="smoke-bg" aria-hidden="true">
  <span class="smoke-wisp smoke--1"></span>
  <span class="smoke-wisp smoke--2"></span>
  <span class="smoke-wisp smoke--3"></span>
  <span class="smoke-wisp smoke--4"></span>
  <span class="smoke-wisp smoke--5"></span>
  <span class="smoke-wisp smoke--6"></span>
</div>

<a href="#main-content" class="skip-link">Ir al contenido principal</a>

<div class="scroll-progress" aria-hidden="true"></div>

<!-- ─── NAV ──────────────────────────────────────────────────────────────── -->
<header class="site-nav" id="site-nav">
  <div class="nav-inner section-inner">
    <a href="#inicio" class="nav-logo" aria-label="Los Ches — inicio">
      <img src="/logo.svg" alt="Los Ches" width="52" height="52" />
    </a>

    <button class="nav-toggle" id="nav-toggle" aria-expanded="false" aria-controls="nav-menu" aria-label="Abrir menú de navegación">
      <span></span><span></span><span></span>
    </button>

    <nav id="nav-menu" class="nav-menu" aria-label="Navegación principal">
      <ul>
        <li><a href="#historia" class="nav-link">Nuestra Historia</a></li>
        <li><a href="#galeria" class="nav-link">Galería</a></li>
        <li><a href="#menu" class="nav-link">Menú</a></li>
        <li><a href="#ubicacion" class="nav-link">Ubicación</a></li>
        <li><a href="#contacto" class="nav-link">Contacto</a></li>
      </ul>
    </nav>

    <a href={whatsappUrl} class="btn btn-outline nav-cta" target="_blank" rel="noopener noreferrer">
      Reservar
    </a>
  </div>
</header>


<main id="main-content">

<!-- ─── HERO ─────────────────────────────────────────────────────────────── -->
<section id="inicio" class="hero" aria-labelledby="hero-heading">
  <!-- Foto full-bleed — directa en .hero para que position:absolute;inset:0 sea relativo a la sección -->
  <div class="hero-image" aria-hidden="true">
    <Image
      src="/images/hero.png"
      alt="Parrilla Los Ches — cortes Angus al kamado con chorizos artesanales"
      class="hero-img"
      width={800}
      height={1000}
      fetchpriority="high"
      loading="eager"
    />
  </div>

  <!-- Atmospheric decoration -->
  <div class="hero-inner section-inner">
    <div class="hero-text">
      <p class="hero-eyebrow">El 1er huarique parrillero de Lima</p>
      <h1 id="hero-heading" class="hero-heading">
        <span class="line"><span class="line-inner">Al fuego.</span></span>
        <span class="line"><span class="line-inner"><em>Sin apuros.</em></span></span>
      </h1>
      <p class="hero-body">
        Carnes Angus de Argentina y Estados Unidos al kamado, parrillas para compartir y el primer huarique parrillero que Lima tenía pendiente.
      </p>
      <div class="hero-actions">
        <a href="#menu" class="btn btn-primary">Ver la Carta</a>
        <a href="#reservas" class="btn btn-outline">
          Reservar una mesa
        </a>
      </div>
    </div>
  </div>

  <div class="hero-scroll-cue" aria-hidden="true"><span></span></div>
</section>


<!-- ─── STATS STRIP ───────────────────────────────────────────────────────── -->
<div class="stats-strip">
  <div class="section-inner">
    <div class="stats-grid" role="list">
      <div class="stat-item reveal" data-reveal role="listitem">
        <span class="stat-number" data-count-to="10" data-count-suffix="+">10+</span>
        <span class="stat-label">Cortes al kamado</span>
      </div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div class="stat-item reveal" data-reveal data-reveal-delay="1" role="listitem">
        <span class="stat-number">Angus</span>
        <span class="stat-label">Importado de Argentina y EE.UU.</span>
      </div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div class="stat-item reveal" data-reveal data-reveal-delay="2" role="listitem">
        <span class="stat-number">San Borja</span>
        <span class="stat-label">Lima, Perú</span>
      </div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div class="stat-item reveal" data-reveal data-reveal-delay="3" role="listitem">
        <span class="stat-number" data-count-to="1" data-count-prefix="#">#1</span>
        <span class="stat-label">Huarique parrillero de Lima</span>
      </div>
    </div>
  </div>
</div>


<!-- ─── HISTORIA 1 ────────────────────────────────────────────────────────── -->
<section id="historia" class="story story--image-left" aria-labelledby="story1-heading">
  <div class="section-inner story-manifesto-header">
    <p class="manifesto-text">Todo lo bueno<br /><em>tarda.</em></p>
  </div>
  <div class="story-inner section-inner">
    <div class="story-image reveal" data-reveal>
      <Image src="/images/historia-1.png" alt="El fundador de Los Ches — pasión y tradición parrillera" class="story-img" loading="lazy" width={600} height={750} />
    </div>
    <div class="story-text reveal" data-reveal data-reveal-delay="1">
      <h2 id="story1-heading">
        Pasión, tradición<br />y amor por la <span class="accent">parrilla.</span>
      </h2>
      <p>
        Los Ches nació de una convicción: que la mejor carne merece el mejor fuego. Por eso elegimos el kamado, una técnica de cocción lenta que transforma cada corte en algo que no se olvida.
      </p>
      <blockquote class="pull-quote">
        "La mejor carne merece el mejor calor."
      </blockquote>
      <p>
        Somos el primer huarique parrillero de Lima — el lugar donde la familia se sienta a la mesa sin mirar el reloj.
      </p>
    </div>
  </div>
</section>


<!-- ─── HISTORIA 2 ────────────────────────────────────────────────────────── -->
<section class="story story--image-right" aria-labelledby="story2-heading">
  <div class="story-inner section-inner">
    <div class="story-text reveal" data-reveal>
      <h2 id="story2-heading">
        El kamado hace<br />la <span class="accent-ember">diferencia.</span>
      </h2>
      <p>
        El kamado retiene el calor y la humedad de una manera que ninguna parrilla convencional puede igualar. Cada corte Angus se cocina a temperatura controlada, con un ahumado natural que potencia el sabor sin taparlo.
      </p>
      <p>
        El punto perfecto lo eliges tú. Término medio, tres cuartos, bien cocido: en Los Ches, cada corte sale como lo pides, siempre perfecto.
      </p>
    </div>
    <div class="story-image reveal" data-reveal data-reveal-delay="1">
      <Image src="/images/gallery-kamado.png" alt="El kamado rojo de Los Ches — técnica japonesa, alma peruana" class="story-img" loading="lazy" width={600} height={750} />
    </div>
  </div>
</section>


<!-- ─── DONENESS SECTION ───────────────────────────────────────────────────── -->
<section class="doneness-section" aria-labelledby="doneness-heading">
  <div class="section-inner">
    <div class="doneness-layout">

      <div class="doneness-left">
        <h2 id="doneness-heading" class="doneness-heading">El punto perfecto.</h2>
        <div class="doneness-image-panel" aria-hidden="true">
        <!-- TODO: replace with real doneness-level photography -->
        <Image class="doneness-img" data-index="0" src="/images/rare.png"        alt="Punto de cocción: Rojo / Sellado"  width={400} height={533} loading="lazy" />
        <Image class="doneness-img" data-index="1" src="/images/medium_rare.png"  alt="Punto de cocción: Término Medio"   width={400} height={533} loading="lazy" />
        <Image class="doneness-img" data-index="2" src="/images/medium.png"       alt="Punto de cocción: Tres Cuartos"    width={400} height={533} loading="lazy" />
        <Image class="doneness-img" data-index="3" src="/images/well_done.png"    alt="Punto de cocción: Bien Cocido"     width={400} height={533} loading="lazy" />
      </div>
      </div>

      <ol class="doneness-items" aria-label="Puntos de cocción">
        <li class="doneness-item" data-index="0">
          <span class="doneness-num">01</span>
          <h3 class="doneness-title">Rojo / Sellado</h3>
          <p class="doneness-meta">2 min por lado · 50°C–52°C</p>
          <p class="doneness-desc">Rojo intenso por dentro, el sabor más puro.</p>
        </li>
        <li class="doneness-item" data-index="1">
          <span class="doneness-num">02</span>
          <h3 class="doneness-title">Término Medio</h3>
          <p class="doneness-meta">3–4 min por lado · 55°C–60°C</p>
          <p class="doneness-desc">Equilibrio perfecto entre jugosidad y sabor.</p>
        </li>
        <li class="doneness-item" data-index="2">
          <span class="doneness-num">03</span>
          <h3 class="doneness-title">Tres Cuartos</h3>
          <p class="doneness-meta">4–5 min por lado · 60°C–65°C</p>
          <p class="doneness-desc">Más cocido, pero aún jugoso y lleno de sabor.</p>
        </li>
        <li class="doneness-item" data-index="3">
          <span class="doneness-num">04</span>
          <h3 class="doneness-title">Bien Cocido</h3>
          <p class="doneness-meta">6 min por lado · 70°C+</p>
          <p class="doneness-desc">Totalmente cocido, sin jugos visibles.</p>
        </li>
      </ol>

    </div>
  </div>
</section>


<!-- ─── MARQUEE ───────────────────────────────────────────────────────────── -->
<div class="marquee" aria-hidden="true">
  <div class="marquee-track">
    <span class="marquee-seq">Al fuego <em>✦</em> Sin apuros <em>✦</em> Angus al kamado <em>✦</em> Para compartir <em>✦</em>&nbsp;</span>
    <span class="marquee-seq">Al fuego <em>✦</em> Sin apuros <em>✦</em> Angus al kamado <em>✦</em> Para compartir <em>✦</em>&nbsp;</span>
  </div>
</div>


<!-- ─── GALERÍA ───────────────────────────────────────────────────────────── -->
<section id="galeria" class="gallery-section" aria-labelledby="gallery-heading">
  <div class="section-inner">
    <div class="section-header reveal" data-reveal>
      <h2 id="gallery-heading">Así se ve Los Ches.</h2>
      <p>El fuego, los cortes, la mesa compartida.</p>
    </div>
    <div class="gallery-grid" role="list">
      <div class="gallery-item reveal gallery-item--1" data-reveal data-reveal-delay="1" role="listitem">
        <button type="button" class="gallery-img-wrap" aria-label="Ampliar foto: Mesa compartida">
          <Image src="/images/historia-2.png" alt="Mesa compartida en Los Ches — parrilla, vino y familia" loading="lazy" class="gallery-img" width={800} height={600} />
          <div class="gallery-overlay" aria-hidden="true"></div>
          <span class="gallery-caption">Mesa compartida</span>
        </button>
      </div>
      <div class="gallery-item reveal gallery-item--2" data-reveal data-reveal-delay="2" role="listitem">
        <button type="button" class="gallery-img-wrap" aria-label="Ampliar foto: Tomahawk">
          <Image src="/images/gallery-tomahawk.png" alt="Tomahawk de Los Ches con chimichurri" loading="lazy" class="gallery-img" width={800} height={600} />
          <div class="gallery-overlay" aria-hidden="true"></div>
          <span class="gallery-caption">Tomahawk</span>
        </button>
      </div>
      <div class="gallery-item reveal gallery-item--3" data-reveal data-reveal-delay="1" role="listitem">
        <button type="button" class="gallery-img-wrap" aria-label="Ampliar foto: Bife Ancho Angus">
          <Image src="/images/gallery-angus.png" alt="Bife Ancho Angus sellado — corte importado al kamado" loading="lazy" class="gallery-img" width={800} height={600} />
          <div class="gallery-overlay" aria-hidden="true"></div>
          <span class="gallery-caption">Bife Ancho Angus</span>
        </button>
      </div>
      <div class="gallery-item reveal gallery-item--4" data-reveal data-reveal-delay="2" role="listitem">
        <button type="button" class="gallery-img-wrap" aria-label="Ampliar foto: Lomo Saltado">
          <Image src="/images/gallery-lomo.png" alt="Lomo Saltado Los Ches — la fusión que nos define" loading="lazy" class="gallery-img" width={800} height={600} />
          <div class="gallery-overlay" aria-hidden="true"></div>
          <span class="gallery-caption">Lomo Saltado</span>
        </button>
      </div>
      <div class="gallery-item reveal gallery-item--5" data-reveal data-reveal-delay="3" role="listitem">
        <button type="button" class="gallery-img-wrap" aria-label="Ampliar foto: Che Burger">
          <Image src="/images/gallery-burger.png" alt="Che Burger — hamburguesa Angus con todo" loading="lazy" class="gallery-img" width={800} height={600} />
          <div class="gallery-overlay" aria-hidden="true"></div>
          <span class="gallery-caption">Che Burger</span>
        </button>
      </div>
    </div>
  </div>
</section>


<!-- ─── MENÚ ──────────────────────────────────────────────────────────────── -->
<section id="menu" class="menu-section" aria-labelledby="menu-heading">
  <div class="section-inner">
    <div class="section-header reveal" data-reveal>
      <h2 id="menu-heading">Nuestra Carta</h2>
      <p>Todos los precios en soles peruanos (S/).</p>
    </div>

    <div class="menu-tabs" role="tablist" aria-label="Categorías del menú">
      {[
        { id: "piqueos",    label: "Piqueos" },
        { id: "parrillas",  label: "Parrillas" },
        { id: "cortes",     label: "Cortes al Kamado" },
        { id: "platos",     label: "Platos" },
        { id: "postres",    label: "Postres" },
        { id: "bebidas",    label: "Bebidas" },
      ].map((tab, i) => (
        <button
          class="tab-btn"
          role="tab"
          aria-selected={i === 0 ? "true" : "false"}
          aria-controls={`panel-${tab.id}`}
          id={`tab-${tab.id}`}
          data-tab={tab.id}
        >
          {tab.label}
        </button>
      ))}
      <span class="tab-indicator" aria-hidden="true"></span>
    </div>

    <div class="tab-panels">

    <!-- PIQUEOS -->
    <div class="tab-panel" id="panel-piqueos" role="tabpanel" aria-labelledby="tab-piqueos">
      <ul class="menu-list">
        <li class="menu-item">
          <div class="menu-item-info">
            <h3>Che Boludos</h3>
            <p>Albóndigas de cerdo en delgada masa frita, bañadas en salsa rosa con dulce picante (6 unidades)</p>
          </div>
          <span class="menu-price">S/ 32</span>
        </li>
        <li class="menu-item">
          <div class="menu-item-info">
            <h3>Musciame de Lomo o Atún Ahumado</h3>
            <p>Servido con tomate picado, palta y tostaditas</p>
          </div>
          <span class="menu-price">S/ 35</span>
        </li>
        <li class="menu-item">
          <div class="menu-item-info">
            <h3>Tomates Capresse</h3>
            <p>Tomates ahumados con mozzarella gratinada, aceite de oliva y albahaca</p>
          </div>
          <span class="menu-price">S/ 32</span>
        </li>
        <li class="menu-item">
          <div class="menu-item-info">
            <h3>Champiñones a la Parrilla</h3>
            <p>Champiñones salteados a la parrilla con chimichurri</p>
          </div>
          <span class="menu-price">S/ 32</span>
        </li>
        <li class="menu-item">
          <div class="menu-item-info">
            <h3>Alitas Rostizadas</h3>
            <p>En salsa BBQ o Búfalo (6 unidades)</p>
          </div>
          <span class="menu-price">S/ 32</span>
        </li>
        <li class="menu-item">
          <div class="menu-item-info">
            <h3>Chorizos Finas Hierbas</h3>
            <p>Al kamado (3 unidades)</p>
          </div>
          <span class="menu-price">S/ 32</span>
        </li>
        <li class="menu-item">
          <div class="menu-item-info">
            <h3>Morcillas</h3>
            <p>Al kamado (3 unidades)</p>
          </div>
          <span class="menu-price">S/ 32</span>
        </li>
      </ul>
    </div>

    <!-- PARRILLAS -->
    <div class="tab-panel is-hidden" id="panel-parrillas" role="tabpanel" aria-labelledby="tab-parrillas">
      <p class="menu-note">Las parrillas para 4, 6 y Los Ches incluyen 50% de descuento en la primera botella de vino de la casa.</p>
      <ul class="menu-list">
        <li class="menu-item">
          <div class="menu-item-info">
            <h3>Parrilla para 1</h3>
            <p>250 g de cuadril Angus americano + papas fritas + ensalada + 1 chorizo artesanal + refresco, gaseosa o agua</p>
          </div>
          <span class="menu-price">S/ 120</span>
        </li>
        <li class="menu-item">
          <div class="menu-item-info">
            <h3>Parrilla para 2</h3>
            <p>500 g de cuadril Angus argentino (2 cortes) + 2 chorizos artesanales + papas fritas + ensalada + 2 copas de vino o 2 gaseosas</p>
          </div>
          <span class="menu-price">S/ 230</span>
        </li>
        <li class="menu-item menu-item--featured">
          <div class="menu-item-info">
            <h3>Parrilla para 4</h3>
            <p>800 g (4 cortes) de cuadril Angus argentino + 1 filete de pollo parrillero + 4 chorizos artesanales + papas fritas + ensalada</p>
          </div>
          <span class="menu-price">S/ 310</span>
        </li>
        <li class="menu-item menu-item--featured">
          <div class="menu-item-info">
            <h3>Parrilla Los Ches <span class="badge">Especial</span></h3>
            <p>1 kg de cuadril Angus argentino + 4 chorizos artesanales + champiñones a la parrilla + papas fritas + ensalada</p>
          </div>
          <span class="menu-price">S/ 350</span>
        </li>
        <li class="menu-item menu-item--featured">
          <div class="menu-item-info">
            <h3>Parrilla para 6</h3>
            <p>1,2 kg (6 cortes) de cuadril Angus argentino + 6 chorizos artesanales + papas fritas + ensalada</p>
          </div>
          <span class="menu-price">S/ 390</span>
        </li>
        <li class="menu-item">
          <div class="menu-item-info">
            <h3>Parrilla de Vegetales</h3>
            <p>Champiñones, zucchini y pimientos con queso Edam derretido</p>
          </div>
          <span class="menu-price">S/ 45</span>
        </li>
      </ul>
    </div>

    <!-- CORTES AL KAMADO -->
    <div class="tab-panel is-hidden" id="panel-cortes" role="tabpanel" aria-labelledby="tab-cortes">
      <p class="menu-note">Cortes importados de Argentina y Estados Unidos. Cada corte se sirve con papas fritas o ensalada.</p>
      <ul class="menu-list">
        <li class="menu-item">
          <div class="menu-item-info">
            <h3>Bife Angosto <span class="menu-weight">250 g</span></h3>
          </div>
          <span class="menu-price">S/ 95</span>
        </li>
        <li class="menu-item">
          <div class="menu-item-info">
            <h3>Bife Angosto <span class="menu-weight">400 g</span></h3>
          </div>
          <span class="menu-price">S/ 145</span>
        </li>
        <li class="menu-item">
          <div class="menu-item-info">
            <h3>Bife Ancho <span class="menu-weight">400 g</span></h3>
          </div>
          <span class="menu-price">S/ 145</span>
        </li>
        <li class="menu-item">
          <div class="menu-item-info">
            <h3>Lomo Fino <span class="menu-weight">250 g</span></h3>
          </div>
          <span class="menu-price">S/ 85</span>
        </li>
        <li class="menu-item">
          <div class="menu-item-info">
            <h3>Lomo Fino <span class="menu-weight">400 g</span></h3>
          </div>
          <span class="menu-price">S/ 130</span>
        </li>
        <li class="menu-item">
          <div class="menu-item-info">
            <h3>Picaña <span class="menu-weight">400 g</span></h3>
          </div>
          <span class="menu-price">S/ 155</span>
        </li>
        <li class="menu-item menu-item--consult">
          <div class="menu-item-info">
            <h3>Entraña Fina</h3>
          </div>
          <span class="menu-price menu-price--consult">Consultar</span>
        </li>
        <li class="menu-item menu-item--consult">
          <div class="menu-item-info">
            <h3>Asado de Tira</h3>
          </div>
          <span class="menu-price menu-price--consult">Consultar</span>
        </li>
        <li class="menu-item menu-item--consult">
          <div class="menu-item-info">
            <h3>Tomahawk</h3>
          </div>
          <span class="menu-price menu-price--consult">Consultar</span>
        </li>
      </ul>

      <div class="menu-subsection">
        <h3 class="menu-subsection-title">Cerdo &amp; Pollo</h3>
        <ul class="menu-list">
          <li class="menu-item">
            <div class="menu-item-info">
              <h3>Bondiola Oriental</h3>
              <p>Acompañada de nabo encurtido y papas fritas</p>
            </div>
            <span class="menu-price">S/ 60</span>
          </li>
          <li class="menu-item">
            <div class="menu-item-info">
              <h3>Bondiola Ahumada</h3>
              <p>Acompañada con papas fritas</p>
            </div>
            <span class="menu-price">S/ 60</span>
          </li>
          <li class="menu-item">
            <div class="menu-item-info">
              <h3>Cerdo Durock Americano — Tomahawk <span class="menu-weight">700 g aprox.</span></h3>
